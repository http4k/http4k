window.onload = function() {
    document.title = "Swagger UI";
    SwaggerUIBundle({
        url: "spec",
        dom_id: "#swagger-ui",
        deepLinking: null,
        displayOperationId: null,
        displayRequestDuration: null,
        requestSnippetsEnabled: null,
        persistAuthorization: null,
        presets: [SwaggerUIBundle.presets.apis],
        layout: "BaseLayout",
        queryConfigEnabled: null,
        tryItOutEnabled: null,
        oauth2RedirectUrl: "http://localhost:9000/openapi/oauth2-redirect.html",
        withCredentials: null
    })
}
