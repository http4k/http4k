<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wiretap: Traffic.test</title>
    <link rel="icon" type="image/png" sizes="32x32" href="https://http4k.org/favicon-32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="https://http4k.org/favicon-16.png">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>:root {
    --color-text: #1d2433;
    --color-text-muted: #5a6577;
    --color-text-mid: #43505f;
    --color-placeholder: #9aa7b6;
    --color-border: #E2E8F1;
    --color-border-subtle: #EEF2F7;
    --color-bg-light: #F5F8FC;
    --color-bg-hover: #E9EEF5;
    --color-primary: #2096F3;
    --color-link: #0f6cb8;
    --color-danger: #dc3545;
    --color-success: #198754;
    --color-warning: #ffc107;
    --color-orange: #EE7D2B;
    --color-inbound: #0FA8E8;
    --color-outbound: #6f42c1;

    --font-sans: 'Space Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;

    --ink: #0B1622;
    --blue: #61C0FF;
    --blue-strong: #2096F3;
    --blue-dark: #0f6cb8;
    --blue-wash: rgba(97, 192, 255, 0.10);

    --radius-sm: 6px;
    --radius: 8px;
    --radius-lg: 12px;
    --shadow: 0 1px 2px rgba(20, 24, 31, 0.04), 0 2px 8px rgba(20, 24, 31, 0.06);
    --shadow-hover: 0 18px 40px -26px rgba(11, 22, 34, 0.3);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: var(--font-sans);
    font-size: 13px;
    background: #fff;
    color: var(--color-text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

.app-header {
    background: radial-gradient(circle at 82% -40%, var(--blue-wash), transparent 60%), url("https://www.http4k.org/images/pipes-hero.svg") no-repeat left top / cover, var(--ink);
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    z-index: 100;
}

.app-header-right {
    display: flex;
    align-items: center;
    gap: 16px;
}

.app-nav {
    display: flex;
    gap: 4px;
}

.app-nav .nav-link {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 500;
}

.app-nav .nav-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.15);
}

.app-nav .nav-link-active {
    color: #fff;
    background: rgba(255, 255, 255, 0.2);
}

.app-header-brand {
    display: flex;
    align-items: center;
    gap: 12px;
}

.app-logo {
    height: 36px;
}

.app-header-title {
    font-size: 18px;
    font-weight: 500;
    color: #fff;
}

.top-tabs {
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 6px 12px;
    background: var(--color-bg-light);
    border-bottom: 1px solid #E2E8F1;
    overflow-x: auto;
    flex-shrink: 0;
}

.top-add-tab {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: var(--color-bg-light);
    border-bottom: 1px solid #E2E8F1;
    flex-shrink: 0;
}

.top-add-tab .form-control-sm {
    font-size: 13px;
    width: 200px;
}

.top-filters {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-bottom: 1px solid #E2E8F1;
    flex-shrink: 0;
}

.form-select-sm,
.form-control-sm {
    font-size: 13px;
    flex: 1;
    min-width: 0;
}

.filter-actions {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
    margin-left: 8px;
}

.app-layout {
    flex: 1;
}

.tab-btn {
    display: flex;
    align-items: center;
    background: transparent;
    color: #1d2433;
    border: none;
    padding: 7px 10px;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
    text-align: left;
    white-space: nowrap;
}

.tab-btn:hover {
    background: #E9EEF5;
}

.tab-btn.active {
    background: #E9EEF5;
    font-weight: 600;
}

.add-tab-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    background: transparent;
    color: #5a6577;
    border: 1px dashed #E2E8F1;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
    white-space: nowrap;
}

.add-tab-btn:hover {
    color: #1d2433;
    border-color: #9aa7b6;
}

.action-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--color-bg-light);
    color: var(--color-text-muted);
    border: none;
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
}

.action-btn:hover {
    color: var(--color-text);
    background: var(--color-bg-hover);
}

.action-btn-primary:hover {
    color: #0f6cb8;
    background: #e7f0ff;
}

.action-btn-danger:hover {
    color: var(--color-danger);
    background: #fee2e2;
}

.list-header {
    display: grid;
    grid-template-columns: var(--grid-cols, 30px 90px 70px 60px minmax(80px, 1fr) minmax(80px, 2fr) 50px 60px);
    gap: 8px;
    padding: 8px 12px;
    background: #fff;
    font-size: 11px;
    font-weight: 600;
    color: #5a6577;
    border-bottom: 1px solid #E2E8F1;
}

.col-resize-handle {
    position: absolute;
    right: -4px;
    top: 0;
    bottom: 0;
    width: 7px;
    cursor: col-resize;
    z-index: 1;
}

.col-resize-handle:hover {
    background: rgba(0, 0, 0, 0.08);
}

.list-body {
    flex: 1;
    overflow-y: auto;
}

.tx-row {
    display: grid;
    grid-template-columns: var(--grid-cols, 30px 90px 70px 60px minmax(80px, 1fr) minmax(80px, 2fr) 50px 60px);
    gap: 8px;
    padding: 6px 12px;
    font-size: 13px;
    border-bottom: 1px solid #EEF2F7;
    cursor: pointer;
}

.tx-row:hover {
    background: #F5F8FC;
}

.tx-row.selected {
    background: #EEF2F7;
}

.dir-in {
    color: var(--color-inbound);
}

.dir-out {
    color: var(--color-outbound);
}

.status-2xx, .status-3xx, .status-4xx, .status-5xx {
    font-weight: 600;
}

.status-2xx {
    color: var(--color-success);
}

.status-3xx {
    color: var(--color-warning);
}

.status-4xx {
    color: var(--color-orange);
}

.status-5xx {
    color: var(--color-danger);
}

.method {
    font-weight: 600;
}

.empty {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--color-placeholder);
    font-size: 14px;
}

.section-label {
    font-size: 12px;
    font-weight: 600;
    color: #5a6577;
    text-transform: uppercase;
}

.code-block {
    background: var(--color-bg-light);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 10px;
    font-size: 12px;
    white-space: pre-wrap;
    word-break: break-word;
    overflow-y: auto;
}

.detail-content {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
}

.detail-section {
    margin-bottom: 16px;
}

.detail-section h3 {
    font-size: 12px;
    color: #5a6577;
    margin-bottom: 6px;
    text-transform: uppercase;
    font-weight: 600;
}

.detail-section pre,
.mcp-client-message pre {
    background: var(--color-bg-light);
    border: 1px solid var(--color-border);
    padding: 10px;
    border-radius: 4px;
    font-size: 13px;
    white-space: pre-wrap;
    word-break: break-all;
    overflow-x: auto;
    color: var(--color-text);
    margin: 0;
}

.data-table {
    width: 100%;
    border-collapse: collapse;
}

.data-table td {
    padding: 4px 8px;
    border-bottom: 1px solid var(--color-border-subtle);
    vertical-align: top;
}

.data-table td:first-child {
    font-weight: 600;
    white-space: nowrap;
}

.header-table {
    font-size: 13px;
}

.header-table td:first-child {
    color: var(--color-link);
    width: 200px;
}

.detail-toolbar {
    margin: -16px -16px 16px -16px;
    padding: 12px 16px;
    background: #F5F8FC;
    border-bottom: 1px solid #E2E8F1;
    display: flex;
    gap: 8px;
    align-items: center;
}

.detail-toolbar .uri {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.badge {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 600;
}

.badge-in {
    color: var(--color-inbound);
}

.badge-out {
    color: var(--color-outbound);
}

.uri-cell {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.filterable {
    cursor: pointer;
}

.filterable:hover {
    text-decoration: underline;
}

.duration {
    color: #5a6577;
    font-size: 12px;
    text-align: right;
    font-variant-numeric: tabular-nums;
}

.detail-content hr {
    border: none;
    border-top: 1px solid #E2E8F1;
    margin: 16px 0;
}

.trace-link-btn {
    background: #e8f4fd;
    color: #0f6cb8;
    border: 1px solid #b6d4fe;
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 12px;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    font-weight: 600;
    font-family: var(--font-mono);
}

.trace-link-btn:hover {
    background: #cfe2ff;
    border-color: #0f6cb8;
}

.timestamp {
    color: #5a6577;
    font-size: 12px;
    font-variant-numeric: tabular-nums;
}

/* Chaos row highlight */
.tx-row-chaos {
    background: #fffde7;
}

.tx-row-chaos:hover {
    background: #fff9c4;
}

/* Chaos page */
.chaos-page {
    padding: 24px;
    max-width: 900px;
    margin: 0 auto;
}

.chaos-status-panel {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
    padding: 16px;
    background: #F5F8FC;
    border: 1px solid #E2E8F1;
    border-radius: 8px;
}

.chaos-engine-status {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
}

.chaos-engine-status h4 {
    font-size: 13px;
    font-weight: 600;
    margin: 0;
    min-width: 70px;
}

.chaos-description {
    font-size: 12px;
    color: #5a6577;
}

.badge-chaos {
    display: inline-block;
    background: #dc3545;
    color: #fff;
    width: 14px;
    height: 14px;
    line-height: 14px;
    text-align: center;
    border-radius: 50%;
    font-size: 9px;
    font-weight: 700;
    vertical-align: middle;
}

.badge-chaos-active,
.badge-chaos-inactive,
.badge-trace {
    padding: 2px 8px;
    border-radius: 3px;
    font-size: 11px;
    font-weight: 600;
}

.badge-chaos-active {
    background: var(--color-danger);
    color: #fff;
}

.badge-chaos-inactive {
    background: var(--color-bg-hover);
    color: var(--color-text-muted);
}

.badge-trace {
    background: #e8f4fd;
    color: var(--color-link);
}

.chaos-sections {
    display: flex;
    gap: 24px;
}

.chaos-section {
    flex: 1;
    border: 1px solid #E2E8F1;
    border-radius: 8px;
    padding: 20px;
}

.chaos-columns {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr auto;
    gap: 20px;
    align-items: start;
}

.chaos-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.chaos-form-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.chaos-form-group label {
    font-size: 12px;
    font-weight: 600;
    color: #5a6577;
    text-transform: uppercase;
}

.chaos-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-self: end;
}

/* Traces page */
.trace-list-header {
    display: grid;
    grid-template-columns: var(--grid-cols, 100px 80px 1fr 120px 50px 70px);
    gap: 8px;
    padding: 8px 12px;
    background: #fff;
    font-size: 11px;
    font-weight: 600;
    color: #5a6577;
    border-bottom: 1px solid #E2E8F1;
}

.trace-row {
    display: grid;
    grid-template-columns: var(--grid-cols, 100px 80px 1fr 120px 50px 70px);
    gap: 8px;
    padding: 6px 12px;
    font-size: 13px;
    border-bottom: 1px solid #EEF2F7;
    cursor: pointer;
}

.trace-service-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: #5a6577;
}

.trace-row:hover {
    background: #F5F8FC;
}

.trace-row.selected {
    background: #EEF2F7;
}

.trace-id {
    font-family: var(--font-mono);
    font-size: 12px;
    color: #0f6cb8;
}

.trace-root-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.trace-span-count {
    text-align: center;
    color: #5a6577;
}

.trace-id-detail {
    font-family: var(--font-mono);
    font-size: 13px;
}

/* Gantt chart */
.gantt-chart {
    padding: 0;
}

.gantt-total-duration {
    margin-left: auto;
    font-size: 12px;
    font-weight: 600;
    color: #5a6577;
    font-variant-numeric: tabular-nums;
}

.gantt-timeline-header {
    display: flex;
    align-items: stretch;
    font-size: 10px;
    color: #9aa7b6;
    border-bottom: 1px solid #E2E8F1;
    padding: 4px 0;
}

.gantt-label-col {
    width: 300px;
    min-width: 200px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0 8px;
    overflow: hidden;
}

.gantt-timeline-col {
    flex: 1;
    position: relative;
    min-height: 20px;
}

.gantt-tick {
    position: absolute;
    top: 2px;
    transform: translateX(-50%);
    font-size: 10px;
    color: #9aa7b6;
}

.gantt-row {
    display: flex;
    align-items: stretch;
    cursor: pointer;
    border-bottom: 1px solid #EEF2F7;
    min-height: 28px;
}

.gantt-row:hover {
    background: #F5F8FC;
}

.gantt-span-name {
    font-weight: 600;
    font-size: 12px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
}

.gantt-gridlines {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    pointer-events: none;
}

.gantt-gridline {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: #EEF2F7;
}

.gantt-bar {
    position: absolute;
    top: 4px;
    bottom: 4px;
    border-radius: 3px;
    min-width: 2px;
    border: 1px solid;
}

.gantt-bar-SERVER {
    background: #a8d4f0;
    border-color: #0f6cb8;
}

.gantt-bar-CLIENT {
    background: #dcc8f0;
    border-color: #6f42c1;
}

.gantt-bar-INTERNAL {
    background: #d5d8dc;
    border-color: #5a6577;
}

.gantt-bar-PRODUCER {
    background: #ffe8a1;
    border-color: #856404;
}

.gantt-bar-CONSUMER {
    background: #b8e6c4;
    border-color: #155724;
}

.span-kind {
    font-size: 10px;
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 3px;
    text-transform: uppercase;
    flex-shrink: 0;
}

.badge-span-SERVER {
    background: #e8f4fd;
    color: #0f6cb8;
}

.badge-span-CLIENT {
    background: #f3e8fd;
    color: #6f42c1;
}

.badge-span-INTERNAL {
    background: #E9EEF5;
    color: #5a6577;
}

.badge-span-PRODUCER {
    background: #fff3cd;
    color: #856404;
}

.badge-span-CONSUMER {
    background: #d4edda;
    color: #155724;
}

/* Gantt detail panel */
.gantt-detail {
    display: none;
    background: var(--color-bg-light);
    border-bottom: 1px solid #E2E8F1;
    padding: 12px 16px;
}

.gantt-detail.expanded {
    display: block;
}

.gantt-detail-columns {
    display: flex;
    gap: 16px;
    margin-bottom: 12px;
}

.gantt-detail-columns:last-child {
    margin-bottom: 0;
}

.gantt-detail-col {
    flex: 1;
    min-width: 0;
}

.span-detail-section {
    margin-bottom: 12px;
}

.span-detail-section:last-child {
    margin-bottom: 0;
}

.span-detail-section h4 {
    font-size: 12px;
    font-weight: 600;
    color: #5a6577;
    text-transform: uppercase;
    margin-bottom: 4px;
}

.span-detail-table {
    font-size: 12px;
}

.span-detail-table td {
    padding: 2px 8px 2px 0;
}

.span-detail-table td:first-child {
    color: var(--color-text-muted);
    width: 180px;
}

.span-detail-table code {
    font-size: 11px;
    background: #E9EEF5;
    padding: 1px 4px;
    border-radius: 2px;
}

/* Span-level events section */
.span-events-section,
.span-links-section {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid #E2E8F1;
}

.span-events-section h4,
.span-links-section h4 {
    font-size: 12px;
    font-weight: 600;
    color: #5a6577;
    text-transform: uppercase;
    margin-bottom: 4px;
}

/* Span-level links */
.span-link {
    padding: 4px 0;
    border-bottom: 1px solid #EEF2F7;
}

.span-link:last-child {
    border-bottom: none;
}

.span-link-trace {
    font-weight: 600;
    font-size: 12px;
}

.span-link-attrs {
    margin-top: 4px;
}

/* Sequence Diagram */
.sequence-diagram {
    margin-top: 16px;
    padding: 16px;
    background: #fff;
    border: 1px solid #E2E8F1;
    border-radius: 4px;
    overflow-x: auto;
}

.sequence-diagram-toolbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 8px;
}

.sequence-diagram .mermaid:not([data-processed]) {
    visibility: hidden;
    height: 0;
    overflow: hidden;
}

.sequence-diagram .mermaid[data-processed] {
    display: flex;
    justify-content: center;
}

/* Panel resize handle */
.panel-resize-handle {
    height: 5px;
    background: #E2E8F1;
    cursor: row-resize;
    flex-shrink: 0;
}

.panel-resize-handle:hover {
    background: #9aa7b6;
}

/* Traffic vertical layout */
.traffic-layout {
    display: flex;
    flex-direction: column;
    flex: none;
    overflow: visible;
}

.traffic-list {
    height: 250px;
    min-height: 120px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.traffic-detail-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.detail-req-resp {
    display: flex;
    gap: 16px;
    flex: 1;
    overflow: hidden;
}

.detail-req-resp-col {
    flex: 1;
    min-width: 0;
    overflow-y: auto;
}

.detail-col-title {
    font-size: 13px;
    font-weight: 600;
    color: #1d2433;
    margin-bottom: 8px;
    padding-bottom: 4px;
    border-bottom: 2px solid #2096F3;
    text-transform: uppercase;
}

/* Otel traces vertical layout */
.otel-layout {
    display: flex;
    flex-direction: column;
}

.otel-trace-list {
    height: 250px;
    min-height: 120px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.otel-detail-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}


/* Severity badges */
.badge-severity-info, .badge-severity-INFO {
    background: #d1e7dd;
    color: #0f5132;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 3px;
    font-weight: 600;
}

.badge-severity-warn, .badge-severity-WARN {
    background: #fff3cd;
    color: #664d03;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 3px;
    font-weight: 600;
}

.badge-severity-error, .badge-severity-ERROR {
    background: #f8d7da;
    color: #842029;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 3px;
    font-weight: 600;
}

/* Expandable detail tables (shared by events and logs) */
.span-logs-section {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid #E2E8F1;
}

.span-logs-section h4 {
    font-size: 12px;
    font-weight: 600;
    color: #5a6577;
    text-transform: uppercase;
    margin-bottom: 4px;
}

.span-event-table,
.span-log-table {
    width: 100%;
    font-size: 12px;
    border-collapse: collapse;
}

.span-event-table thead th,
.span-log-table thead th {
    text-align: left;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    padding: 4px 8px;
    border-bottom: 1px solid var(--color-border);
}

.span-event-row,
.span-log-row {
    cursor: pointer;
}

.span-event-row td,
.span-log-row td {
    padding: 4px 8px;
    border-bottom: 1px solid var(--color-border-subtle);
}

.span-event-row:hover td,
.span-log-row:hover td {
    background: var(--color-bg-hover);
}

.span-log-body {
    font-weight: 600;
}

.span-event-detail-row,
.span-log-detail-row {
    display: none;
}

.span-event-detail-row.expanded,
.span-log-detail-row.expanded {
    display: table-row;
}

.span-event-detail-row td,
.span-log-detail-row td {
    padding: 8px 8px 8px 16px;
    border-bottom: 1px solid var(--color-border-subtle);
}

.span-log-detail-columns {
    display: flex;
    gap: 24px;
}

.span-log-detail-section {
    flex: 1;
    margin-bottom: 8px;
}

.span-log-detail-section h5 {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 0 0 4px;
}

.span-event-fields,
.span-log-fields {
    margin-top: 4px;
}

/* Trace-level orphan logs section */
.trace-logs-section {
    padding: 12px 16px;
    border-top: 1px solid #E2E8F1;
}

.trace-logs-section h4 {
    margin: 0 0 8px;
    font-size: 13px;
    font-weight: 600;
}

/* Replay badge */
.badge-replay {
    display: inline-block;
    background: #2096F3;
    color: #fff;
    width: 14px;
    height: 14px;
    line-height: 14px;
    text-align: center;
    border-radius: 50%;
    font-size: 9px;
    font-weight: 700;
    vertical-align: middle;
}

.tx-row-replay {
    background: #f0f4ff;
}

.tx-row-replay:hover {
    background: #e0eaff;
}

/* Client page */
.client-page {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
}

.client-toolbar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: #F5F8FC;
    border-bottom: 1px solid #E2E8F1;
    flex-shrink: 0;
}

.client-method {
}

.client-url {
    flex: 1;
    font-family: var(--font-mono);
}

.client-request-section {
    height: 280px;
    min-height: 120px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.client-form {
    flex: 1;
    overflow-y: auto;
    padding: 12px 16px;
}

.client-form-columns {
    display: flex;
    gap: 24px;
}

.client-form-columns .client-section {
    flex: 1;
    min-width: 0;
}

.client-detail-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.client-section h4 {
    font-size: 12px;
    color: #5a6577;
    margin-bottom: 8px;
    text-transform: uppercase;
    font-weight: 600;
}

.client-headers {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.client-header-row {
    display: flex;
    gap: 8px;
    align-items: center;
}

.client-header-row input {
    flex: 1;
}

.client-remove-header {
    flex-shrink: 0;
    padding: 2px 8px;
    font-size: 14px;
    line-height: 1;
}

.client-add-header {
    align-self: flex-start;
    margin-top: 2px;
}

.client-section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
}

.client-section-header h4 {
    margin-bottom: 0;
}

.client-content-type {
}

.client-body {
    font-family: var(--font-mono);
    font-size: 13px;
}

/* ── Overview page ── */

.mcp-logo {
    width: 28px;
    height: 28px;
}

.mcp-status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    animation: mcp-pulse 2s ease-in-out infinite;
    vertical-align: middle;
}

@keyframes mcp-pulse {
    0%, 100% {
        box-shadow: 0 0 4px rgba(34, 197, 94, 0.3);
    }
    50% {
        box-shadow: 0 0 10px rgba(34, 197, 94, 0.6);
    }
}

.mcp-url {
    text-decoration: none;
}

.mcp-url:hover code {
    text-decoration: underline;
}

.mcp-url code {
    background: #F5F8FC;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 12px;
    color: #43505f;
}

.mcp-copy-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: #5a6577;
    padding: 2px 4px;
    font-size: 13px;
    line-height: 1;
    border-radius: 4px;
}

.mcp-copy-btn:hover {
    color: #1d2433;
    background: #E9EEF5;
}

.overview-page {
    padding: 24px;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
}

.overview-metrics {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    margin-bottom: 24px;
}

.metric-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: #fff;
    border: 1px solid #E2E8F1;
    border-radius: 8px;
    padding: 20px;
}

.metric-icon {
    font-size: 28px;
    color: #5a6577;
    flex-shrink: 0;
}

.metric-body {
    min-width: 0;
}

.metric-value {
    font-size: 28px;
    font-weight: 700;
    line-height: 1.1;
    color: #1d2433;
}

.metric-label {
    font-size: 13px;
    color: #5a6577;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.metric-sub {
    margin-top: 6px;
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
    font-size: 12px;
}

.overview-charts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
}

.chart-card {
    background: #fff;
    border: 1px solid #E2E8F1;
    border-radius: 8px;
    padding: 20px;
}

.chart-card h5 {
    font-size: 14px;
    font-weight: 600;
    color: #43505f;
    margin-bottom: 16px;
}

.chart-container {
    position: relative;
    height: 220px;
}

.overview-traffic-chart {
    margin-bottom: 24px;
}

.chart-card-wide {
    width: 100%;
}

.chart-container-wide {
    height: 180px;
}

/* ── MCP Client panel ── */

.mcp-client-subnav {
    display: flex;
    gap: 2px;
    padding: 8px 16px;
    background: var(--color-bg-light);
    border-bottom: 1px solid #E2E8F1;
    flex-shrink: 0;
}

.mcp-client-tab {
    padding: 6px 16px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    color: #43505f;
}

.mcp-client-tab:hover {
    background: rgba(0, 0, 0, 0.05);
    color: #1d2433;
}

.mcp-client-tab-active {
    background: #2096F3;
    color: #fff !important;
}

.mcp-client-tab-active:hover {
    background: #0f6cb8;
}

.mcp-client-layout {
    display: flex;
    flex: 1;
    overflow: hidden;
}

.mcp-client-list {
    width: 320px;
    min-width: 280px;
    border-right: 1px solid #E2E8F1;
    overflow-y: auto;
    background: var(--color-bg-light);
}

.mcp-client-list-header {
    padding: 10px 14px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    color: #5a6577;
    background: var(--color-bg-light);
    border-bottom: 1px solid #E2E8F1;
}

.mcp-client-item {
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-border-subtle);
    cursor: pointer;
}

.mcp-client-item:hover {
    background: var(--color-bg-hover);
}

.mcp-client-item-active {
    background: #e7f0ff;
    border-left: 3px solid #2096F3;
}

.mcp-client-item-name {
    font-size: 13px;
    font-weight: 600;
    color: #1d2433;
}

.mcp-client-item-desc {
    font-size: 12px;
    color: #5a6577;
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.mcp-client-item-uri {
    font-size: 11px;
    color: #9aa7b6;
    margin-top: 2px;
    font-family: var(--font-mono);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.mcp-client-detail {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.mcp-client-detail > .empty {
    padding: 20px;
}

.mcp-client-detail-form {
    padding: 20px;
    height: auto;
    overflow-y: visible;
}

.mcp-app-iframe {
    width: 100%;
    height: 100%;
    border: none;
}

.mcp-client-detail-header h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 4px;
}

.mcp-client-detail-header p {
    font-size: 13px;
    color: #5a6577;
    margin-bottom: 16px;
}

.mcp-client-detail-form .client-section {
    margin-bottom: 16px;
}

.mcp-client-detail .client-detail-panel {
    padding: 16px 20px;
    overflow-y: auto;
}

.mcp-client-field {
    margin-bottom: 10px;
}

.mcp-client-field small {
    display: block;
    color: #5a6577;
    font-size: 11px;
    margin-top: 2px;
}

.mcp-client-result {
    margin-top: 16px;
}

.mcp-client-result > label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    color: #5a6577;
    margin-bottom: 4px;
}

.mcp-client-message {
    margin-bottom: 12px;
    border: 1px solid #E2E8F1;
    border-radius: 4px;
    overflow: hidden;
}

.mcp-client-message pre {
    font-size: 12px;
    word-break: break-word;
    padding: 10px;
}

.mcp-client-detail-form > .action-btn {
    margin-top: 12px;
    align-self: flex-start;
}

.mcp-client-detail-form code {
    background: var(--color-bg-light);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 12px;
}

.mcp-client-field > label {
    font-size: 13px;
    font-weight: 600;
    color: #1d2433;
}

.mcp-client-field input[type="text"],
.mcp-client-field select {
    margin-top: 4px;
}

.mcp-client-field input[type="checkbox"] {
    margin-top: 6px;
}

.args-mode-bar {
    display: flex;
    gap: 2px;
    margin-bottom: 8px;
}

.args-mode-tab {
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 12px;
    cursor: pointer;
    color: #5a6577;
    background: transparent;
    user-select: none;
}

.args-mode-tab:hover {
    background: rgba(0, 0, 0, 0.05);
    color: #1d2433;
}

.args-mode-tab-active {
    background: #2096F3;
    color: #fff !important;
}

.args-mode-tab-active:hover {
    background: #0f6cb8;
}

.mcp-client-role {
    display: inline-block;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    background: #E9EEF5;
    color: #43505f;
}

#swagger-ui {
    .schemes-server-container {
        display: none;
    }

    .title > span {
        display: none;
    }

    .main > a {
        display: none;
    }

    .main.title {
        display: none;
    }

    .expand-operation {
        display: none;
    }
}

/* ── http4k design-system alignment ── */

/* Mono "kicker" treatment for uppercase labels (mirrors the website) */
.section-label,
.detail-col-title,
.metric-label,
.detail-section h3,
.client-section h4,
.chaos-form-group label,
.span-detail-section h4,
.span-detail-section h5,
.mcp-client-list-header {
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
}

/* Softer card corners + subtle shadow */
.metric-card,
.chart-card,
.chaos-section,
.chaos-status-panel {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
}

    .trace-link-btn, a.action-btn { display: none; }
    .md-link-btn {
        position: fixed;
        bottom: 1rem;
        right: 1rem;
        background: var(--color-bg-light);
        color: var(--color-text-muted);
        padding: 6px 10px;
        border-radius: 6px;
        font-size: 13px;
        text-decoration: none;
        border: 1px solid var(--color-border);
        z-index: 200;
    }
    .md-link-btn:hover {
        color: var(--color-text);
        background: var(--color-bg-hover);
    }
    </style>
</head>
<body>
<header class="app-header">
    <div class="app-header-brand">
        <a href="https://http4k.org" target="_blank"><img class="app-logo" src="https://www.http4k.org/images/logo.png" alt="http4k"></a>
        <span class="app-header-title">Wiretap</span>
    </div>
</header>
<h2 class="p-3">Traffic.test</h2>
<ul class="nav nav-tabs px-3" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#traffic-tab" type="button" role="tab">Traffic</button>
    </li>
</ul>
<div class="tab-content">
    <div class="tab-pane show active" id="traffic-tab" role="tabpanel">
        <div>
        <div id="detail-panel" class="detail-content">
    <div class="detail-toolbar">
        <span class="badge badge-in">INBOUND</span>
        <span class="method">GET</span>
        <span class="status-2xx status">200</span>
        <span class="uri" title="/api/test">/api/test</span>
        <span class="duration">42ms</span>
        <span class="timestamp">00:00:00.000</span>
        <button class="action-btn"
                data-on:click="copyCurl(evt.currentTarget)">
            Copy cURL
        </button>
        <a href="/_wiretap/traffic/1/har" class="action-btn" download="transaction-1.har">
            Download HAR
        </a>
        <a href="/_wiretap/inbound?import=1" class="action-btn">
            Import to Inbound Client
        </a>
        <pre class="curl-data" hidden>curl -X GET &quot;/api/test&quot;</pre>
    </div>
    <div class="detail-req-resp">
        <div class="detail-req-resp-col">
            <h3 class="detail-col-title">Request</h3>
            <div class="detail-section">
                <h3>Headers</h3>
                <table class="data-table header-table">
                </table>
            </div>
        </div>
        <div class="detail-req-resp-col">
            <h3 class="detail-col-title">Response</h3>
            <div class="detail-section">
                <h3>Headers</h3>
                <table class="data-table header-table">
                </table>
            </div>
            <div class="detail-section">
                <h3>Body</h3>
                <pre>test response</pre>
            </div>
        </div>
    </div>
</div>

        </div>
    </div>
<footer style="text-align: center; padding: 2rem 0 1rem; font-size: 0.85rem; color: #6c757d;">
    Generated by http4k Wiretap Intercept · <a href="https://wiretap.http4k.org" target="_blank" style="color: #6c757d;">wiretap.http4k.org</a>
</footer>
<a href="Traffic.test.md" class="md-link-btn">View as Markdown</a>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
function copyCurl(btn) {
  const pre = btn.closest('.detail-toolbar').querySelector('.curl-data');
  if (pre) {
        navigator.clipboard.writeText(pre.textContent).then(function() {
            var orig = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(function() { btn.textContent = orig; }, 1500);
        });
    }
}
function copyMermaid(btn) {
    var container = btn.closest('.sequence-diagram');
    var pre = container && (container.querySelector('.mermaid-source') || container.querySelector('.mermaid'));
    if (pre) {
        navigator.clipboard.writeText(pre.textContent.trim()).then(function() {
            var orig = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(function() { btn.textContent = orig; }, 1500);
        });
    }
}
document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-on\\:click]');
    if (btn) {
        var fn = btn.getAttribute('data-on:click');
        if (fn.indexOf('copyCurl') === 0) copyCurl(btn);
        if (fn.indexOf('copyMermaid') === 0) copyMermaid(btn);
    }
});
</script>
<script type="module">
import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

mermaid.initialize({
    startOnLoad: false,
    theme: 'base',
    themeVariables: {
        primaryColor: '#e8f4fd',
        primaryBorderColor: '#0A53BE',
        primaryTextColor: '#212529',
        lineColor: '#212529',
        signalColor: '#212529',
        signalTextColor: '#212529',
        actorBkg: '#e8f4fd',
        actorBorder: '#0A53BE',
        actorTextColor: '#212529',
        actorLineColor: '#6c757d',
        background: '#f8f9fa',
        fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
    }
});

const nodes = document.querySelectorAll('.mermaid');
if (nodes.length > 0) mermaid.run({ nodes });
</script>
</body>
</html>
