event: datastar-patch-elements
data: elements <div id="detail-panel" class="detail-content">    <div class="detail-toolbar">        <span class="badge badge-in">INBOUND</span>        <span class="method">GET</span>        <span class="status-2xx status">200</span>        <span class="uri" title="/test">/test</span>        <span class="duration">10ms</span>        <span class="timestamp">00:00:00.000</span>                <button class="action-btn"                data-on:click="copyCurl(evt.currentTarget)">            Copy cURL        </button>        <a href="/_wiretap/traffic/1/har" class="action-btn" download="transaction-1.har">            Download HAR        </a>                <a href="/_wiretap/inbound?import=1" class="action-btn">            Import to Inbound Client        </a>                <pre class="curl-data" hidden>curl -X GET &quot;/test&quot;</pre>    </div>    <div class="detail-req-resp">        <div class="detail-req-resp-col">            <h3 class="detail-col-title">Request</h3>                        <div class="detail-section">                <h3>Headers</h3>                <table class="data-table header-table">                                    </table>            </div>                    </div>        <div class="detail-req-resp-col">            <h3 class="detail-col-title">Response</h3>            <div class="detail-section">                <h3>Headers</h3>                <table class="data-table header-table">                                    </table>            </div>                    </div>    </div></div>
data: selector #detail-panel

