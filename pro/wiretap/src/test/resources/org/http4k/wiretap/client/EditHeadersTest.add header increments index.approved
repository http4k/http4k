event: datastar-patch-signals
data: signals {"headers":{"0":{"name":"Accept","value":"text/html"},"1":{"name":"","value":""}}}
data: onlyIfMissing false

event: datastar-patch-elements
data: elements <div class="client-header-row">
data: elements     <input type="text" class="form-control form-control-sm" data-bind="headers.0.name" placeholder="Header name">
data: elements     <input type="text" class="form-control form-control-sm" data-bind="headers.0.value" placeholder="Value">
data: elements     <button class="action-btn action-btn-danger client-remove-header"
data: elements             data-on:click="@post('/_wiretap/inbound/headers/remove/0')">×
data: elements     </button>
data: elements </div>
data: elements <div class="client-header-row">
data: elements     <input type="text" class="form-control form-control-sm" data-bind="headers.1.name" placeholder="Header name">
data: elements     <input type="text" class="form-control form-control-sm" data-bind="headers.1.value" placeholder="Value">
data: elements     <button class="action-btn action-btn-danger client-remove-header"
data: elements             data-on:click="@post('/_wiretap/inbound/headers/remove/1')">×
data: elements     </button>
data: elements </div>
data: elements <button class="action-btn client-add-header"
data: elements         data-on:click="@post('/_wiretap/inbound/headers/add')">+ Add Header
data: elements </button>
data: elements 
data: selector #client-headers
data: mode inner

