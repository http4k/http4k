data: elements     var target = e.target.getAttribute('data-bs-target');
data: elements     if (!target) return;
data: elements     var pane = document.querySelector(target);
data: elements     if (!pane) return;
data: elements     pane.querySelectorAll('.mermaid[data-processed]').forEach(function(el) {
data: elements         var source = el.closest('.sequence-diagram');
data: elements         source = source && source.querySelector('.mermaid-source');
data: elements         if (source) {
data: elements             el.removeAttribute('data-processed');
data: elements             el.textContent = source.textContent;
data: elements         }
data: elements     });
data: elements     var toRender = pane.querySelectorAll('.mermaid:not([data-processed])');
