event: datastar-patch-elements
data: elements <div id="trace-detail-panel" class="detail-content">
data: elements     <div class="detail-toolbar">
data: elements         <span class="badge badge-trace">TRACE</span>
data: elements         <span class="trace-id-detail" title="00000000000000000000000000000001">00000000</span>
data: elements         <span class="gantt-total-duration">1ms</span>
data: elements         <a href="/_wiretap/traffic?trace=00000000000000000000000000000001" class="trace-link-btn">Traffic</a>
data: elements     </div>
data: elements     <div class="gantt-chart">
data: elements         <div class="gantt-timeline-header">
data: elements             <div class="gantt-label-col"></div>
data: elements             <div class="gantt-timeline-col">
data: elements                 <span class="gantt-tick" style="left: 0%">0%</span>
data: elements                 <span class="gantt-tick" style="left: 25%">25%</span>
data: elements                 <span class="gantt-tick" style="left: 50%">50%</span>
data: elements                 <span class="gantt-tick" style="left: 75%">75%</span>
data: elements                 <span class="gantt-tick" style="left: 100%">100%</span>
data: elements             </div>
data: elements         </div>
data: elements         <div class="gantt-row" onclick="this.nextElementSibling.classList.toggle('expanded')">
data: elements             <div class="gantt-label-col" style="padding-left: 0em;">
data: elements                 <span class="span-kind badge-span-SERVER">SERVER</span>
data: elements                 <span class="gantt-span-name">test</span>
data: elements                 <span class="duration">1ms</span>
data: elements             </div>
data: elements             <div class="gantt-timeline-col">
data: elements                 <div class="gantt-gridlines">
data: elements                     <div class="gantt-gridline" style="left: 25%"></div>
data: elements                     <div class="gantt-gridline" style="left: 50%"></div>
data: elements                     <div class="gantt-gridline" style="left: 75%"></div>
data: elements                 </div>
data: elements                 <div class="gantt-bar gantt-bar-SERVER" style="left: 0%; width: 100%;" title="test (1ms)"></div>
data: elements             </div>
data: elements         </div>
data: elements         <div id="span-detail-1234567890abcdef" class="gantt-detail">
data: elements             <div class="gantt-detail-columns">
data: elements                 <div class="gantt-detail-col">
data: elements                     <div class="span-detail-section">
data: elements                         <h4>Span Info</h4>
data: elements                         <table class="data-table span-detail-table">
data: elements                             <tr>
data: elements                                 <td>Name</td>
data: elements                                 <td>test</td>
data: elements                             </tr>
data: elements                             <tr>
data: elements                                 <td>Span ID</td>
data: elements                                 <td><code title="1234567890abcdef">12345678</code></td>
data: elements                             </tr>
data: elements                             <tr>
data: elements                                 <td>Parent Span ID</td>
data: elements                                 <td><code title="0000000000000000">00000000</code></td>
data: elements                             </tr>
data: elements                             <tr>
data: elements                                 <td>Kind</td>
data: elements                                 <td>SERVER</td>
data: elements                             </tr>
data: elements                             <tr>
data: elements                                 <td>Status</td>
data: elements                                 <td>OK</td>
data: elements                             </tr>
data: elements                             <tr>
data: elements                                 <td>Duration</td>
data: elements                                 <td>1ms</td>
data: elements                             </tr>
data: elements                         </table>
data: elements                     </div>
data: elements                 </div>
data: elements             </div>
data: elements             <div class="span-logs-section">
data: elements                 <h4>Logs</h4>
data: elements                 <table class="data-table span-log-table">
data: elements                     <thead>
data: elements                         <tr>
data: elements                             <th>Time</th>
data: elements                             <th>Severity</th>
data: elements                             <th>key</th>
data: elements                         </tr>
data: elements                     </thead>
data: elements                     <tbody>
data: elements                         <tr class="span-log-row" onclick="this.nextElementSibling.classList.toggle('expanded')">
data: elements                             <td class="timestamp">00:00:00.001</td>
data: elements                             <td><span class="badge badge-severity-INFO">INFO</span></td>
data: elements                             <td>value</td>
data: elements                         </tr>
data: elements                         <tr class="span-log-detail-row">
data: elements                             <td colspan="99">
data: elements                                 <div class="span-log-detail-columns">
data: elements                                     <div class="span-log-detail-section">
data: elements                                         <h5>Attributes</h5>
data: elements                                         <table class="data-table span-detail-table span-log-fields">
data: elements                                             <tr><td>key</td><td>value</td></tr>
data: elements                                         </table>
data: elements                                     </div>
data: elements                                     <div class="span-log-detail-section">
data: elements                                         <h5>Body</h5>
data: elements                                         <table class="data-table span-detail-table span-log-fields">
data: elements                                             <tr><td>body</td><td>something happened</td></tr>
data: elements                                         </table>
data: elements                                     </div>
data: elements                                 </div>
data: elements                             </td>
data: elements                         </tr>
data: elements                     </tbody>
data: elements                 </table>
data: elements             </div>
data: elements         </div>
data: elements     </div>
data: elements     <div id="trace-diagram-panel" data-init="@get('/_wiretap/otel/diagram/00000000000000000000000000000001')"></div>
data: elements </div>
data: elements 
data: selector #trace-detail-panel

