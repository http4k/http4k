data: elements <script>
data: elements (function() {
data: elements     var container = document.currentScript.previousElementSibling;
data: elements 
data: elements     function hidePanes() {
data: elements         var firstPane = container.querySelector('[data-diagram-pane]');
data: elements         container.querySelectorAll('[data-diagram-pane]').forEach(function(p) {
data: elements             if (p !== firstPane) p.classList.remove('show', 'active');
data: elements         });
data: elements     }
data: elements 
data: elements     var total = container.querySelectorAll('.mermaid').length;
data: elements     if (total === 0) {
data: elements         hidePanes();
data: elements     } else {
data: elements         var check = setInterval(function() {
data: elements             if (container.querySelectorAll('.mermaid[data-processed]').length >= total) {
data: elements                 clearInterval(check);
data: elements                 hidePanes();
data: elements             }
data: elements         }, 50);
data: elements     }
data: elements })();
data: elements document.addEventListener('click', function(e) {
data: elements     var btn = e.target.closest('[data-diagram-tab]');
data: elements     if (!btn) return;
data: elements     var container = btn.closest('.trace-analysis');
data: elements     var tabName = btn.getAttribute('data-diagram-tab');
data: elements     container.querySelectorAll('[data-diagram-tab]').forEach(function(b) { b.classList.remove('active'); });
data: elements     container.querySelectorAll('[data-diagram-pane]').forEach(function(p) { p.classList.remove('show', 'active'); });
data: elements     btn.classList.add('active');
data: elements     var pane = container.querySelector('[data-diagram-pane="' + tabName + '"]');
data: elements     if (pane) pane.classList.add('show', 'active');
data: elements });
