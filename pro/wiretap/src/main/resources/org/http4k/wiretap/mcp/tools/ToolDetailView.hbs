<div id="detail-panel" class="mcp-client-detail" data-signals="{toolName: '{{name}}', toolArgs: '{}', argsMode: 'form'{{#each fields}}, field__{{this.name}}: '{{this.defaultValue}}'{{/each}} }">
    <div class="client-request-section mcp-client-detail-form">
        <div class="mcp-client-detail-header">
            <h3>{{name}}</h3>
            <p>{{description}}</p>
        </div>
        <div class="client-section">
            <div class="args-mode-bar">
                <span class="args-mode-tab" data-class-args-mode-tab-active="$argsMode==='form'" data-on:click="$argsMode='form'">Form</span>
                <span class="args-mode-tab" data-class-args-mode-tab-active="$argsMode==='json'" data-on:click="$argsMode='json'">JSON</span>
            </div>
            <form data-show="$argsMode==='form'" id="tool-form" onsubmit="return false">
                {{#if fields}}
                {{#each fields}}
                <div class="mcp-client-field">
                    <label>{{this.name}}{{#if this.required}} *{{/if}}</label>
                    {{#if this.description}}<small>{{this.description}}</small>{{/if}}
                    {{#if this.isEnum}}
                    <select class="form-control form-control-sm" data-bind="field__{{this.name}}" {{#if this.required}} required{{/if}}>
                    <option value=""></option>
                    {{#each this.enumValues}}
                    <option value="{{this}}">{{this}}</option>
                    {{/each}}
                    </select>
                    {{/if}}
                    {{#if this.isBoolean}}
                    <input type="checkbox" data-bind="field__{{this.name}}" {{#if this.required}} required{{/if}}/>
                    {{/if}}
                    {{#if this.isText}}
                    <input type="text" class="form-control form-control-sm" data-bind="field__{{this.name}}" placeholder="{{this.type}}" {{#if this.required}} required{{/if}}/>
                    {{/if}}
                </div>
                {{/each}}
                {{else}}
                <p class="text-muted">No parameters</p>
                {{/if}}
            </form>
            <div data-show="$argsMode==='json'">
                <textarea class="form-control form-control-sm" style="font-family: monospace" rows="6" data-bind="toolArgs" placeholder="{}">{}</textarea>
            </div>
        </div>
        <button class="action-btn action-btn-primary"
                data-on:click="if($argsMode==='form'){const f=document.getElementById('tool-form');if(!f.reportValidity())return;const o={};{{#each fields}}if($field__{{this.name}}!=='')o['{{this.name}}']=$field__{{this.name}};{{/each}}$toolArgs=JSON.stringify(o)};@post('/_wiretap/mcp/tools/call')">Call Tool
        </button>
    </div>
    <div class="panel-resize-handle"></div>
    <div class="client-detail-panel">
        <div id="tool-result" class="mcp-client-result"></div>
    </div>
</div>
