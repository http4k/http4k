<div class="trace-diagrams">
<ul class="nav nav-tabs px-3 pt-3" role="tablist">
    <#if sequenceDiagram?has_content>
    <li class="nav-item">
        <button class="nav-link active" data-diagram-tab="sequence" type="button" role="tab">Sequence</button>
    </li>
    </#if>
    <#if interactionDiagram?has_content>
    <li class="nav-item">
        <button class="nav-link<#if !sequenceDiagram?has_content> active</#if>" data-diagram-tab="interaction" type="button" role="tab">Interactions</button>
    </li>
    </#if>
    <#if timingEntries?has_content>
    <li class="nav-item">
        <button class="nav-link<#if !sequenceDiagram?has_content && !interactionDiagram?has_content> active</#if>" data-diagram-tab="timing" type="button" role="tab">Timing</button>
    </li>
    </#if>
    <#if errorTrace?has_content>
    <li class="nav-item">
        <button class="nav-link" data-diagram-tab="error" type="button" role="tab">Errors</button>
    </li>
    </#if>
    <#if criticalPath?has_content>
    <li class="nav-item">
        <button class="nav-link" data-diagram-tab="critical-path" type="button" role="tab">Critical Path</button>
    </li>
    </#if>
</ul>
<div class="tab-content">
    <#if sequenceDiagram?has_content>
    <div class="tab-pane show active" data-diagram-pane="sequence" role="tabpanel">
        <div class="sequence-diagram">
            <div class="sequence-diagram-toolbar">
                <button class="action-btn" data-on:click="copyMermaid(evt.currentTarget)">Copy Mermaid</button>
            </div>
            <pre class="mermaid">${sequenceDiagram?no_esc}</pre>
            <pre class="mermaid-source" style="display:none">${sequenceDiagram?no_esc}</pre>
        </div>
    </div>
    </#if>
    <#if interactionDiagram?has_content>
    <div class="tab-pane show active" data-diagram-pane="interaction" role="tabpanel">
        <div class="sequence-diagram">
            <div class="sequence-diagram-toolbar">
                <button class="action-btn" data-on:click="copyMermaid(evt.currentTarget)">Copy Mermaid</button>
            </div>
            <pre class="mermaid">${interactionDiagram?no_esc}</pre>
            <pre class="mermaid-source" style="display:none">${interactionDiagram?no_esc}</pre>
        </div>
    </div>
    </#if>
    <#if timingEntries?has_content>
    <div class="tab-pane show active" data-diagram-pane="timing" role="tabpanel">
        <div class="timing-table" style="padding: 1rem;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Service</th>
                        <th>Operation</th>
                        <th>Kind</th>
                        <th style="text-align: right;">Duration</th>
                        <th style="width: 30%;">% of Total</th>
                    </tr>
                </thead>
                <tbody>
                    <#list timingEntries as entry>
                    <tr<#if entry.error> style="color: #dc3545;"</#if>>
                        <td>${entry.serviceName}</td>
                        <td>${entry.operation}</td>
                        <td>${entry.kind}</td>
                        <td style="text-align: right;">${entry.durationMs}ms</td>
                        <td>
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <div style="flex: 1; background: #e9ecef; border-radius: 4px; height: 8px;">
                                    <div style="width: ${entry.percentOfTotal}%; background: <#if entry.error>#e57373<#else>#90a4ae</#if>; height: 100%; border-radius: 4px;"></div>
                                </div>
                                <span style="min-width: 3rem; text-align: right;">${entry.percentOfTotal?string("0.#")}%</span>
                            </div>
                        </td>
                    </tr>
                    </#list>
                </tbody>
            </table>
        </div>
    </div>
    </#if>
    <#if errorTrace?has_content>
    <div class="tab-pane show active" data-diagram-pane="error" role="tabpanel">
        <div class="sequence-diagram">
            <div class="sequence-diagram-toolbar">
                <button class="action-btn" data-on:click="copyMermaid(evt.currentTarget)">Copy Mermaid</button>
            </div>
            <pre class="mermaid">${errorTrace?no_esc}</pre>
            <pre class="mermaid-source" style="display:none">${errorTrace?no_esc}</pre>
        </div>
    </div>
    </#if>
    <#if criticalPath?has_content>
    <div class="tab-pane" data-diagram-pane="critical-path" role="tabpanel">
        <div class="sequence-diagram">
            <div class="sequence-diagram-toolbar">
                <button class="action-btn" data-on:click="copyMermaid(evt.currentTarget)">Copy Mermaid</button>
            </div>
            <pre class="mermaid">${criticalPath?no_esc}</pre>
            <pre class="mermaid-source" style="display:none">${criticalPath?no_esc}</pre>
        </div>
    </div>
    </#if>
</div>
</div>
<script>
(function() {
    var container = document.currentScript.previousElementSibling;

    function hidePanes() {
        var firstPane = container.querySelector('[data-diagram-pane]');
        container.querySelectorAll('[data-diagram-pane]').forEach(function(p) {
            if (p !== firstPane) p.classList.remove('show', 'active');
        });
    }

    var unprocessed = container.querySelectorAll('.mermaid:not([data-processed])');
    if (unprocessed.length === 0) {
        hidePanes();
    } else {
        var observer = new MutationObserver(function() {
            if (container.querySelectorAll('.mermaid:not([data-processed])').length === 0) {
                observer.disconnect();
                hidePanes();
            }
        });
        observer.observe(container, { childList: true, subtree: true, attributes: true, attributeFilter: ['data-processed'] });
    }
})();
document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-diagram-tab]');
    if (!btn) return;
    var container = btn.closest('.trace-diagrams');
    var tabName = btn.getAttribute('data-diagram-tab');
    container.querySelectorAll('[data-diagram-tab]').forEach(function(b) { b.classList.remove('active'); });
    container.querySelectorAll('[data-diagram-pane]').forEach(function(p) { p.classList.remove('show', 'active'); });
    btn.classList.add('active');
    var pane = container.querySelector('[data-diagram-pane="' + tabName + '"]');
    if (pane) pane.classList.add('show', 'active');
});
</script>
