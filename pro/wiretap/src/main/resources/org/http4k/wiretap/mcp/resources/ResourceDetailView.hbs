<div id="detail-panel" class="mcp-client-detail" data-signals="{resourceUri: '{{uri}}'}">
    <div class="client-request-section mcp-client-detail-form">
        <div class="mcp-client-detail-header">
            <h3>{{name}}</h3>
            <p>{{description}}</p>
        </div>
        <div class="client-section">
            <h4>URI</h4>
            <code>{{uri}}</code>
            {{#if mimeType}}<br><h4 style="margin-top: 8px">MIME Type</h4><code>{{mimeType}}</code>{{/if}}
        </div>
        <button class="action-btn action-btn-primary" data-on:click="@post('/_wiretap/mcp/resources/read')">Read Resource</button>
    </div>
    <div class="panel-resize-handle"></div>
    <div class="client-detail-panel">
        <div id="resource-result" class="mcp-client-result"></div>
    </div>
</div>
