{{#>org/http4k/wiretap/layout pageTitle="OTel"}}
{{#partial "body"}}
<body data-signals="{{initialSignals}}">
{{> org/http4k/wiretap/header navOTel=true}}
<div class="app-layout otel-layout">
    <div class="otel-trace-list">
        <div class="trace-list-header">
            <span>Time</span><span>Trace ID</span><span>Root Span</span><span>Service</span><span>Spans</span><span class="duration">Duration</span>
        </div>
        <div class="list-body" id="trace-list" data-init="@get('/_wiretap/otel/list')"></div>
    </div>
    <div class="panel-resize-handle"></div>
    <div class="otel-detail-panel">
        {{#if deepLinkTrace}}
        <div id="trace-detail-panel" data-init="@get('/_wiretap/otel/{{deepLinkTrace}}')">Loading trace...</div>
        {{else}}
        <div id="trace-detail-panel" class="empty">Select a trace</div>
        {{/if}}
    </div>
</div>
<script type="module">
import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

mermaid.initialize({
    startOnLoad: false,
    theme: 'base',
    themeVariables: {
        primaryColor: '#e8f4fd',
        primaryBorderColor: '#0A53BE',
        primaryTextColor: '#212529',
        lineColor: '#212529',
        signalColor: '#212529',
        signalTextColor: '#212529',
        actorBkg: '#e8f4fd',
        actorBorder: '#0A53BE',
        actorTextColor: '#212529',
        actorLineColor: '#6c757d',
        background: '#f8f9fa',
        fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
    }
});

window._mermaidRender = async function() {
    const nodes = document.querySelectorAll('.mermaid:not([data-processed])');
    if (nodes.length === 0) return;
    await mermaid.run({ nodes: nodes });
};
window._mermaidRender();
</script>
{{> org/http4k/wiretap/footer}}
</body>
{{/partial}}
{{/layout}}
