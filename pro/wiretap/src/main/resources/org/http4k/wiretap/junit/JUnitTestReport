<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wiretap: ${testName}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="https://http4k.org/favicon-32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="https://http4k.org/favicon-16.png">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>${css?no_esc}
    .trace-link-btn, a.action-btn { display: none; }
    </style>
</head>
<body>
<header class="app-header">
    <div class="app-header-brand">
        <a href="https://http4k.org" target="_blank"><img class="app-logo" src="https://www.http4k.org/images/logo.png" alt="http4k"></a>
        <span class="app-header-title">Wiretap</span>
    </div>
</header>
<h2 class="p-3">${testName}</h2>
<ul class="nav nav-tabs px-3" role="tablist">
    <#if traces?has_content>
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#traces-tab" type="button" role="tab">Traces</button>
    </li>
    </#if>
    <#if traffic?has_content>
    <li class="nav-item">
        <button class="nav-link<#if !traces?has_content> active</#if>" data-bs-toggle="tab" data-bs-target="#traffic-tab" type="button" role="tab">Traffic</button>
    </li>
    </#if>
    <#if stdOut?has_content>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#stdout-tab" type="button" role="tab">Std Out</button>
    </li>
    </#if>
    <#if stdErr?has_content>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#stderr-tab" type="button" role="tab">Std Err</button>
    </li>
    </#if>
</ul>
<div class="tab-content">
    <#if traces?has_content>
    <div class="tab-pane show active" id="traces-tab" role="tabpanel">
        <#list traces as item>
        <div class="app-layout otel-layout" style="grid-template-columns: 1fr;">
            <div class="otel-detail-panel">
                ${item.ganttHtml?no_esc}
            </div>
            ${item.diagramsHtml?no_esc}
        </div>
        </#list>
    </div>
    </#if>
    <#if traffic?has_content>
    <div class="tab-pane<#if !traces?has_content> show active</#if>" id="traffic-tab" role="tabpanel">
        <#list traffic as item>
        ${item.trafficHtml?no_esc}
        </#list>
    </div>
    </#if>
    <#if stdOut?has_content>
    <div class="tab-pane" id="stdout-tab" role="tabpanel">
        <pre class="p-3" style="white-space: pre-wrap; word-break: break-word;">${stdOut}</pre>
    </div>
    </#if>
    <#if stdErr?has_content>
    <div class="tab-pane" id="stderr-tab" role="tabpanel">
        <pre class="p-3" style="white-space: pre-wrap; word-break: break-word;">${stdErr}</pre>
    </div>
    </#if>
</div>
<footer style="text-align: center; padding: 2rem 0 1rem; font-size: 0.85rem; color: #6c757d;">
    Generated by http4k Wiretap · <a href="https://wiretap.http4k.org" target="_blank" style="color: #6c757d;">wiretap.http4k.org</a>
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
function copyCurl(btn) {
    var pre = btn.closest('.detail-toolbar').querySelector('.curl-data');
    if (pre) {
        navigator.clipboard.writeText(pre.textContent).then(function() {
            var orig = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(function() { btn.textContent = orig; }, 1500);
        });
    }
}
function copyMermaid(btn) {
    var container = btn.closest('.sequence-diagram') || btn.closest('.otel-detail-panel') || btn.closest('.otel-layout');
    var pre = container && (container.querySelector('.mermaid-source') || container.querySelector('.mermaid'));
    if (pre) {
        navigator.clipboard.writeText(pre.textContent.trim()).then(function() {
            var orig = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(function() { btn.textContent = orig; }, 1500);
        });
    }
}
document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-on\\:click]');
    if (btn) {
        var fn = btn.getAttribute('data-on:click');
        if (fn.indexOf('copyCurl') === 0) copyCurl(btn);
        if (fn.indexOf('copyMermaid') === 0) copyMermaid(btn);
    }
});
</script>
<script type="module">
import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

mermaid.initialize({
    startOnLoad: false,
    theme: 'base',
    themeVariables: {
        primaryColor: '#e8f4fd',
        primaryBorderColor: '#0A53BE',
        primaryTextColor: '#212529',
        lineColor: '#212529',
        signalColor: '#212529',
        signalTextColor: '#212529',
        actorBkg: '#e8f4fd',
        actorBorder: '#0A53BE',
        actorTextColor: '#212529',
        actorLineColor: '#6c757d',
        background: '#f8f9fa',
        fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
    }
});

const nodes = document.querySelectorAll('.mermaid');
if (nodes.length > 0) mermaid.run({ nodes });
</script>
</body>
</html>
