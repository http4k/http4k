<#list tabs as tab>
<div class="tab-btn" data-tab-id="${tab.id}" data-class:active="$activeView==='${tab.id}'"
     data-on:click="@post('/_wiretap/traffic/views/${tab.id}/activate')">
    <span>${tab.name}</span>
</div>
</#list>
<div class="add-tab-btn" data-on:click="$showAddView=!$showAddView; $name=''"><i class="bi bi-plus-lg"></i> Add Tab</div>
<div class="action-btn action-btn-danger" style="margin-left: auto" data-on:click="@delete('/_wiretap/traffic')"><i class="bi bi-trash"></i> Clear</div>
