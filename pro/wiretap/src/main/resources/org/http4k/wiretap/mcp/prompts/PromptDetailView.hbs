<div id="detail-panel" class="mcp-client-detail" data-signals="{promptName: '{{name}}', promptArgs: '{}'}">
    <div class="client-request-section mcp-client-detail-form">
        <div class="mcp-client-detail-header">
            <h3>{{name}}</h3>
            <p>{{description}}</p>
        </div>
        {{#if arguments}}
        <div class="client-section">
            <h4>Arguments</h4>
            {{#each arguments}}
            <div class="mcp-client-field">
                <label>{{this.name}}{{#if this.required}} *{{/if}}</label>
                {{#if this.description}}<small>{{this.description}}</small>{{/if}}
            </div>
            {{/each}}
        </div>
        {{/if}}
        <div class="client-section">
            <h4>Arguments (JSON)</h4>
            <textarea class="form-control form-control-sm" style="font-family: monospace" rows="6" data-bind="promptArgs" placeholder="{}">{}</textarea>
        </div>
        <button class="action-btn action-btn-primary" data-on:click="@post('/_wiretap/mcp/prompts/create')">Get Prompt</button>
    </div>
    <div class="panel-resize-handle"></div>
    <div class="client-detail-panel">
        <div id="prompt-result" class="mcp-client-result"></div>
    </div>
</div>
