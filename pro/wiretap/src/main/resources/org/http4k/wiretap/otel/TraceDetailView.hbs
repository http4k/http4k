<div id="trace-detail-panel" class="detail-content">
    <div class="detail-toolbar">
        <span class="badge badge-trace">TRACE</span>
        <span class="trace-id-detail" title="{{detail.traceId}}">{{shortTraceId}}</span>
        <span class="gantt-total-duration">{{detail.totalDurationMs}}ms</span>
        <a href="/_wiretap/traffic?trace={{detail.traceId}}" class="trace-link-btn">Traffic</a>
    </div>
    <div class="gantt-chart">
        <div class="gantt-timeline-header">
            <div class="gantt-label-col"></div>
            <div class="gantt-timeline-col">
                <span class="gantt-tick" style="left: 0%">0%</span>
                <span class="gantt-tick" style="left: 25%">25%</span>
                <span class="gantt-tick" style="left: 50%">50%</span>
                <span class="gantt-tick" style="left: 75%">75%</span>
                <span class="gantt-tick" style="left: 100%">100%</span>
            </div>
        </div>
        {{#each spans}}
        <div class="gantt-row" onclick="this.nextElementSibling.classList.toggle('expanded')">
            <div class="gantt-label-col" style="padding-left: {{span.depth}}em;">
                <span class="span-kind badge-span-{{span.kind}}">{{span.kind}}</span>
                <span class="gantt-span-name">{{span.name}}</span>
                <span class="duration">{{span.durationMs}}ms</span>
            </div>
            <div class="gantt-timeline-col">
                <div class="gantt-gridlines">
                    <div class="gantt-gridline" style="left: 25%"></div>
                    <div class="gantt-gridline" style="left: 50%"></div>
                    <div class="gantt-gridline" style="left: 75%"></div>
                </div>
                <div class="gantt-bar gantt-bar-{{span.kind}}" style="left: {{span.startOffsetPercent}}%; width: {{span.widthPercent}}%;" title="{{span.name}} ({{span.durationMs}}ms)"></div>
            </div>
        </div>
        <div id="span-detail-{{span.spanId}}" class="gantt-detail">
            <div class="gantt-detail-columns">
                <div class="gantt-detail-col">
                    <div class="span-detail-section">
                        <h4>Span Info</h4>
                        <table class="data-table span-detail-table">
                            <tr>
                                <td>Name</td>
                                <td>{{span.name}}</td>
                            </tr>
                            <tr>
                                <td>Span ID</td>
                                <td><code title="{{span.spanId}}">{{shortSpanId}}</code></td>
                            </tr>
                            {{#if span.parentSpanId}}
                            <tr>
                                <td>Parent Span ID</td>
                                <td><code title="{{span.parentSpanId}}">{{shortParentSpanId}}</code></td>
                            </tr>
                            {{/if}}
                            <tr>
                                <td>Kind</td>
                                <td>{{span.kind}}</td>
                            </tr>
                            <tr>
                                <td>Status</td>
                                <td>{{span.statusCode}}{{#if span.statusDescription}} — {{span.statusDescription}}{{/if}}</td>
                            </tr>
                            <tr>
                                <td>Duration</td>
                                <td>{{span.durationMs}}ms</td>
                            </tr>
                            {{#if span.serviceName}}
                            <tr>
                                <td>Service</td>
                                <td>{{span.serviceName}}</td>
                            </tr>
                            {{/if}}
                        </table>
                    </div>
                </div>
                {{#if span.attributes}}
                <div class="gantt-detail-col">
                    <div class="span-detail-section">
                        <h4>Attributes</h4>
                        <table class="data-table span-detail-table">
                            {{#each span.attributes}}
                            <tr>
                                <td>{{key}}</td>
                                <td>{{value}}</td>
                            </tr>
                            {{/each}}
                        </table>
                    </div>
                </div>
                {{/if}}
                {{#if span.baggageAttributes}}
                <div class="gantt-detail-col">
                    <div class="span-detail-section">
                        <h4>Baggage</h4>
                        <table class="data-table span-detail-table">
                            {{#each span.baggageAttributes}}
                            <tr>
                                <td>{{key}}</td>
                                <td>{{value}}</td>
                            </tr>
                            {{/each}}
                        </table>
                    </div>
                </div>
                {{/if}}
                {{#if span.resourceAttributes}}
                <div class="gantt-detail-col">
                    <div class="span-detail-section">
                        <h4>Resource Attributes</h4>
                        <table class="data-table span-detail-table">
                            {{#each span.resourceAttributes}}
                            <tr>
                                <td>{{key}}</td>
                                <td>{{value}}</td>
                            </tr>
                            {{/each}}
                        </table>
                    </div>
                </div>
                {{/if}}
            </div>
            {{#if eventRows}}
            <div class="span-events-section">
                <h4>Events</h4>
                <table class="data-table span-event-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Time</th>
                            <th>Attributes</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each eventRows}}
                        <tr class="span-event-row" onclick="this.nextElementSibling.classList.toggle('expanded')">
                            <td>{{event.name}}</td>
                            <td class="timestamp">+{{event.timestampMs}}ms</td>
                            <td>{{attributeCount}}</td>
                        </tr>
                        <tr class="span-event-detail-row">
                            <td colspan="99">
                                {{#if event.attributes}}
                                <table class="data-table span-detail-table span-event-fields">
                                    {{#each event.attributes}}
                                    <tr><td>{{key}}</td><td>{{value}}</td></tr>
                                    {{/each}}
                                </table>
                                {{/if}}
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{/if}}
            {{#if links}}
            <div class="span-links-section">
                <h4>Links</h4>
                {{#each links}}
                <div class="span-link">
                    <span class="span-link-trace" title="{{traceId}}">{{shortTraceId}}</span>
                    <code title="{{spanId}}">{{shortSpanId}}</code>
                    {{#if attributes}}
                    <table class="data-table span-detail-table span-link-attrs">
                        {{#each attributes}}
                        <tr>
                            <td>{{key}}</td>
                            <td>{{value}}</td>
                        </tr>
                        {{/each}}
                    </table>
                    {{/if}}
                </div>
                {{/each}}
            </div>
            {{/if}}
            {{#if logRows}}
            <div class="span-logs-section">
                <h4>Logs</h4>
                <table class="data-table span-log-table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Severity</th>
                            {{#each logAttrColumns}}
                            <th>{{this}}</th>
                            {{/each}}
                        </tr>
                    </thead>
                    <tbody>
                        {{#each logRows}}
                        <tr class="span-log-row" onclick="this.nextElementSibling.classList.toggle('expanded')">
                            <td class="timestamp">{{log.timestamp}}</td>
                            <td><span class="badge badge-severity-{{log.severity}}">{{log.severity}}</span></td>
                            {{#each columnValues}}
                            <td>{{this}}</td>
                            {{/each}}
                        </tr>
                        <tr class="span-log-detail-row">
                            <td colspan="99">
                                <div class="span-log-detail-columns">
                                    {{#if log.attributes}}
                                    <div class="span-log-detail-section">
                                        <h5>Attributes</h5>
                                        <table class="data-table span-detail-table span-log-fields">
                                            {{#each log.attributes}}
                                            <tr><td>{{key}}</td><td>{{value}}</td></tr>
                                            {{/each}}
                                        </table>
                                    </div>
                                    {{/if}}
                                    {{#if log.bodyFields}}
                                    <div class="span-log-detail-section">
                                        <h5>Body</h5>
                                        <table class="data-table span-detail-table span-log-fields">
                                            {{#each log.bodyFields}}
                                            <tr><td>{{key}}</td><td>{{value}}</td></tr>
                                            {{/each}}
                                        </table>
                                    </div>
                                    {{/if}}
                                </div>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{/if}}
        </div>
        {{/each}}
    </div>
    {{#if orphanLogRows}}
    <div class="trace-logs-section">
        <h4>Logs (unlinked to span)</h4>
        <table class="data-table span-log-table">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Severity</th>
                    <th>Body</th>
                    {{#each orphanLogAttrColumns}}
                    <th>{{this}}</th>
                    {{/each}}
                </tr>
            </thead>
            <tbody>
                {{#each orphanLogRows}}
                <tr class="span-log-row" onclick="this.nextElementSibling.classList.toggle('expanded')">
                    <td class="timestamp">{{log.timestamp}}</td>
                    <td><span class="badge badge-severity-{{log.severity}}">{{log.severity}}</span></td>
                    <td class="span-log-body">{{log.body}}</td>
                    {{#each columnValues}}
                    <td>{{this}}</td>
                    {{/each}}
                </tr>
                <tr class="span-log-detail-row">
                    <td colspan="99">
                        <div class="span-log-detail-columns">
                            {{#if log.attributes}}
                            <div class="span-log-detail-section">
                                <h5>Attributes</h5>
                                <table class="data-table span-detail-table span-log-fields">
                                    {{#each log.attributes}}
                                    <tr><td>{{key}}</td><td>{{value}}</td></tr>
                                    {{/each}}
                                </table>
                            </div>
                            {{/if}}
                            {{#if log.bodyFields}}
                            <div class="span-log-detail-section">
                                <h5>Body</h5>
                                <table class="data-table span-detail-table span-log-fields">
                                    {{#each log.bodyFields}}
                                    <tr><td>{{key}}</td><td>{{value}}</td></tr>
                                    {{/each}}
                                </table>
                            </div>
                            {{/if}}
                        </div>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
    {{/if}}
    <div id="trace-diagram-panel" data-init="@get('/_wiretap/otel/diagram/{{detail.traceId}}')"></div>
</div>
