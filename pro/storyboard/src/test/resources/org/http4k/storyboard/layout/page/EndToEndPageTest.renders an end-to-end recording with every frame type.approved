<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Storyboard: renders an end-to-end recording with every frame type</title>
<link rel="icon" type="image/png" sizes="32x32" href="https://http4k.org/favicon-32.png">
<link rel="icon" type="image/png" sizes="16x16" href="https://http4k.org/favicon-16.png">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
<style>
:root {
    --color-text: #212529;
    --color-text-muted: #6c757d;
    --color-border: #dee2e6;
    --color-bg-light: #f8f9fa;
    --color-bg-hover: #e9ecef;
    --color-accent: #fd7e14;
    --color-link: #0d6efd;
}
* { box-sizing: border-box; }
html, body { height: 100%; }
body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #fff;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
}
.app-header {
    background: url("https://http4k.org/images/pipes-hero.svg"), linear-gradient(135deg, #59AFF5 0%, #2096F3 50%, #61C0FF 100%);
    background-size: cover;
    background-position: center;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
}
.app-header-brand { display: flex; align-items: center; gap: 12px; }
.app-logo { height: 36px; }
.app-header-title { font-size: 18px; font-weight: 500; color: #fff; }
h1.test-title { margin: 0; padding: 12px 20px; font-size: 16px; font-weight: 500; color: var(--color-text); background: var(--color-bg-light); border-bottom: 1px solid var(--color-border); flex-shrink: 0; display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
h1.test-title .test-breadcrumb { font-size: 16px; font-weight: 500; color: inherit; text-decoration: none; }
h1.test-title a.test-breadcrumb:hover { text-decoration: underline; }
h1.test-title .test-sep { color: var(--color-text-muted); font-weight: 400; }
h1.test-title .test-heading { font-weight: 500; }
footer.app-footer { text-align: center; padding: 10px 0; font-size: 0.85rem; color: var(--color-text-muted); border-top: 1px solid var(--color-border); background: var(--color-bg-light); flex-shrink: 0; }
footer.app-footer a { color: var(--color-text-muted); }
.mode-toggle { display: inline-flex; gap: 6px; align-items: center; }
.mode-toggle .btn-group {
    position: relative;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    overflow: hidden;
    display: inline-flex;
}
.mode-toggle .btn-group::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: translateY(100%);
    transition: transform 0.25s ease;
    z-index: 0;
}
.mode-toggle .btn-group:has(.btn-check:checked)::before { transform: translateY(0); }
.mode-toggle .btn {
    position: relative;
    z-index: 1;
    font-size: 11px;
    padding: 4px 14px;
    text-align: center;
    background: transparent !important;
    border: 0 !important;
    border-radius: 999px !important;
    color: var(--color-text-muted);
    transition: color 0.25s ease;
    box-shadow: none !important;
}
.mode-toggle .btn-check:checked + .btn { color: #fff; }
body:has(#mode-story:checked) [data-level="Context"],
body:has(#mode-story:checked) [data-level="Detail"] { display: none; }
body:has(#mode-context:checked) [data-level="Detail"] { display: none; }
body { font-size: 14px; overflow-y: auto; }
.page-mode-bar { position: sticky; top: 0; z-index: 10; background: var(--color-bg-light); border-bottom: 1px solid var(--color-border); padding: 8px 16px; display: flex; justify-content: flex-end; }
main.page-view { flex: 1; padding: 24px; max-width: 1080px; width: 100%; margin: 0 auto; }
main.page-view section.chapter { margin-bottom: 32px; padding-left: 0; }
main.page-view section.chapter.depth-2, main.page-view section.chapter.depth-3, main.page-view section.chapter.depth-4 { padding-left: 18px; border-left: 2px solid var(--color-border); }
main.page-view section.chapter > h2, main.page-view section.chapter > h3, main.page-view section.chapter > h4, main.page-view section.chapter > h5, main.page-view section.chapter > h6 { margin: 4px 0 16px; font-weight: 600; color: var(--color-text); }
main.page-view section.chapter > h2 { font-size: 22px; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; }
main.page-view section.chapter > h3 { font-size: 18px; color: var(--color-text-muted); }
main.page-view section.chapter > h4 { font-size: 16px; color: var(--color-text-muted); }
article.frame { margin: 0 0 20px; padding: 12px 14px; background: #fff; border: 1px solid var(--color-border); border-radius: 6px; }
article.frame > header { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 8px; }
article.frame > header .title { font-weight: 600; font-size: 14px; color: var(--color-text); }
article.frame > header .level { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-text-muted); padding: 2px 8px; border: 1px solid var(--color-border); border-radius: 999px; }
article.frame .notes { margin: 0 0 10px; color: var(--color-text-muted); font-size: 13px; font-style: italic; }
article.frame .frame-wrapper { position: relative; }
article.frame .capture-frame { width: 100%; height: 420px; border: 1px solid var(--color-border); border-radius: 4px; background: #fff; display: block; }
article.frame .frame-overlay { position: absolute; top: 0; left: 0; right: 16px; bottom: 16px; background: transparent; cursor: default; }
</style>

</head>
<body>
<header class="app-header">
    <div class="app-header-brand">
        <a href="https://http4k.org" target="_blank"><img class="app-logo" src="https://http4k.org/images/logo.png" alt="Storyboard"></a>
        <span class="app-header-title">Storyboard</span>
    </div>
</header>
<h1 class="test-title">
    <a class="test-breadcrumb" href="index.html">EndToEndPageTest</a><span class="test-sep">›</span>
    <span class="test-heading">renders an end-to-end recording with every frame type</span>
</h1>
<div class="page-mode-bar"><div class="mode-toggle" role="group" aria-label="Detail level">
    <div class="btn-group">
        <input type="radio" class="btn-check" name="mode" id="mode-story" autocomplete="off" checked>
        <label class="btn" for="mode-story">Story</label>
    </div>
    <div class="btn-group">
        <input type="radio" class="btn-check" name="mode" id="mode-context" autocomplete="off" >
        <label class="btn" for="mode-context">Context</label>
    </div>
    <div class="btn-group">
        <input type="radio" class="btn-check" name="mode" id="mode-detail" autocomplete="off" >
        <label class="btn" for="mode-detail">Detail</label>
    </div>
</div>
</div>
<main class="page-view">
    <section class="chapter depth-1">
        <h2>renders an end-to-end recording with every frame type</h2>
        
        
        
        
            <article class="frame" data-level="Story">
                <header>
                    <span class="title">Sample image</span>
                    <span class="level">Story</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="0"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
    <section class="chapter depth-2">
        
        <h3>Setup</h3>
        
        
        
            <article class="frame" data-level="Context">
                <header>
                    <span class="title">Splash</span>
                    <span class="level">Context</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="1"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Context">
                <header>
                    <span class="title">Sample source</span>
                    <span class="level">Context</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="2"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
    </section>
    <section class="chapter depth-2">
        
        <h3>Run</h3>
        
        
        
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">postgresql SELECT</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="3"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">SERVER GET data</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="4"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">CLIENT GET /data</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="5"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">SERVER GET home</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="6"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">CLIENT GET /home</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="7"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Story">
                <header>
                    <span class="title">Home</span>
                    <span class="level">Story</span>
                </header>
                <p class="notes">first navigation</p>
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="8"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
    <section class="chapter depth-3">
        
        
        <h4>Detail</h4>
        
        
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">postgresql SELECT</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="9"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">SERVER GET data</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="10"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">CLIENT GET /data</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="11"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">SERVER GET detail</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="12"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">CLIENT GET /detail</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="13"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Detail">
                <header>
                    <span class="title">click [By.id: next]</span>
                    <span class="level">Detail</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="14"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
            <article class="frame" data-level="Story">
                <header>
                    <span class="title">Detail page</span>
                    <span class="level">Story</span>
                </header>
                <p class="notes">after the click</p>
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="15"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
    </section>
    </section>
    <section class="chapter depth-2">
        
        <h3>Wrap-up</h3>
        
        
        
            <article class="frame" data-level="Context">
                <header>
                    <span class="title">Outro</span>
                    <span class="level">Context</span>
                </header>
                
                <div class="frame-wrapper">
                    <iframe class="capture-frame" sandbox="allow-scripts" data-index="16"></iframe>
                    <div class="frame-overlay" aria-hidden="true"></div>
                </div>
            </article>
    </section>
    </section>
</main>
<script type="application/json" id="storyboard-frames">[{"title":"Sample image","notes":"","dom":"","level":"Story","domAssets":{}},{"title":"Splash","notes":"","dom":"","level":"Context","domAssets":{}},{"title":"Sample source","notes":"","dom":"","level":"Context","domAssets":{}},{"title":"postgresql SELECT","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"SERVER GET data","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"CLIENT GET /data","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"SERVER GET home","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"CLIENT GET /home","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"Home","notes":"first navigation","dom":"H4sIAAAAAAAA/y2OsQ7CMAxE936FyQ9ErMj1AkgMSDAgIcZQuyRSGldphODvaVMmn+5s38PN4bK/Pa5H8GWI1GAd6MUxYQklCp10ELSrRluTBp/KX2oA0G/pLrGrO7NerJHO6lgY+qwDhJQkwyT5HTrZAU4la3qRlxh1DdH+PbRjfeAgcGuSfIoBn6VvjWUpLkRDLwUWGZcjN2PYyjE3L9Q/u92JM8wAAAA=","level":"Story","domAssets":{}},{"title":"postgresql SELECT","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"SERVER GET data","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"CLIENT GET /data","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"SERVER GET detail","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"CLIENT GET /detail","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"click [By.id: next]","notes":"","dom":"H4sIAAAAAAAA/zVNOw7CMAzdcwpzAqsrevJCmWFgYTSKRSK5bYS8cHvSANPT++MwX063+/VMJRaXhAEoplkQNdxkttDq4C8DDy/hseW3JCKU6Rehpk/r/jTk9lezhh4Jtkgx943qutoL3Dm49SEeS723P38AmPB8ZpAAAAA=","level":"Detail","domAssets":{}},{"title":"Detail page","notes":"after the click","dom":"H4sIAAAAAAAA/zVNOw7CMAzdcwpzAqsrevJCmWFgYTSKRSK5bYS8cHvSANPT++MwX063+/VMJRaXhAEoplkQNdxkttDq4C8DDy/hseW3JCKU6Rehpk/r/jTk9lezhh4Jtkgx943qutoL3Dm49SEeS723P38AmPB8ZpAAAAA=","level":"Story","domAssets":{}},{"title":"Outro","notes":"","dom":"","level":"Context","domAssets":{}}]</script>
<script>
window.domInflate = (() => {
  const inflate = async (b64) => {
    const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
    const stream = new Blob([bytes]).stream().pipeThrough(new DecompressionStream('gzip'));
    return await new Response(stream).text();
  };
  const inflateBytes = async (b64) => {
    const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
    const stream = new Blob([bytes]).stream().pipeThrough(new DecompressionStream('gzip'));
    return new Uint8Array(await new Response(stream).arrayBuffer());
  };
  const bytesToBase64 = (bytes) => {
    let bin = '';
    const chunk = 0x8000;
    for (let i = 0; i < bytes.length; i += chunk) {
      bin += String.fromCharCode.apply(null, bytes.subarray(i, Math.min(i + chunk, bytes.length)));
    }
    return btoa(bin);
  };
  const inflateAssets = async (assets) => {
    const entries = await Promise.all(
      Object.entries(assets || {}).map(async ([url, asset]) => {
        try { return [url, { mime: asset.mimeType, bytes: await inflateBytes(asset.content) }]; }
        catch (e) { return null; }
      })
    );
    const decoded = Object.fromEntries(entries.filter(Boolean));
    const out = {};
    for (const [url, a] of Object.entries(decoded)) {
      if (a.mime.startsWith('text/css')) continue;
      out[url] = 'data:' + a.mime + ';base64,' + bytesToBase64(a.bytes);
    }
    for (const [url, a] of Object.entries(decoded)) {
      if (!a.mime.startsWith('text/css')) continue;
      let text = new TextDecoder().decode(a.bytes);
      for (const [refUrl, dataUri] of Object.entries(out)) text = text.split(refUrl).join(dataUri);
      out[url] = 'data:' + a.mime + ';base64,' + btoa(unescape(encodeURIComponent(text)));
    }
    return out;
  };
  const rewriteAssets = (html, urlMap) => {
    for (const [orig, replacement] of Object.entries(urlMap)) {
      html = html.split(orig).join(replacement);
    }
    return html;
  };
  const inflateAndRewrite = async (frame) => {
    const [html, urlMap] = await Promise.all([inflate(frame.dom), inflateAssets(frame.domAssets)]);
    return rewriteAssets(html, urlMap);
  };
  return { inflateAndRewrite };
})();
</script>
<script>
(function () {
  const frames = JSON.parse(document.getElementById('storyboard-frames').textContent);
  document.querySelectorAll('iframe.capture-frame[data-index]').forEach(async f => {
    const i = parseInt(f.getAttribute('data-index'), 10);
    f.srcdoc = await domInflate.inflateAndRewrite(frames[i]);
  });
})();
</script>
<footer class="app-footer">
    Generated by http4k Storyboard · <a href="https://http4k.org" target="_blank">http4k.org</a>
</footer>
</body>
</html>
