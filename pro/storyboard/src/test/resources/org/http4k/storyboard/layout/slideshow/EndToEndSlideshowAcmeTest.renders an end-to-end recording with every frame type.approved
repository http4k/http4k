<script>
window.domInflate = (() => {
  const inflate = async (b64) => {
    const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
    const stream = new Blob([bytes]).stream().pipeThrough(new DecompressionStream('gzip'));
    return await new Response(stream).text();
  };
  const inflateBytes = async (b64) => {
    const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
    const stream = new Blob([bytes]).stream().pipeThrough(new DecompressionStream('gzip'));
    return new Uint8Array(await new Response(stream).arrayBuffer());
  };
  const bytesToBase64 = (bytes) => {
    let bin = '';
    const chunk = 0x8000;
    for (let i = 0; i < bytes.length; i += chunk) {
      bin += String.fromCharCode.apply(null, bytes.subarray(i, Math.min(i + chunk, bytes.length)));
    }
    return btoa(bin);
  };
  const inflateAssets = async (assets) => {
    const entries = await Promise.all(
      Object.entries(assets || {}).map(async ([url, asset]) => {
        try { return [url, { mime: asset.mimeType, bytes: await inflateBytes(asset.content) }]; }
        catch (e) { return null; }
      })
    );
    const decoded = Object.fromEntries(entries.filter(Boolean));
    const out = {};
    for (const [url, a] of Object.entries(decoded)) {
      if (a.mime.startsWith('text/css')) continue;
      out[url] = 'data:' + a.mime + ';base64,' + bytesToBase64(a.bytes);
    }
    for (const [url, a] of Object.entries(decoded)) {
      if (!a.mime.startsWith('text/css')) continue;
      let text = new TextDecoder().decode(a.bytes);
      for (const [refUrl, dataUri] of Object.entries(out)) text = text.split(refUrl).join(dataUri);
      out[url] = 'data:' + a.mime + ';base64,' + btoa(unescape(encodeURIComponent(text)));
    }
    return out;
  };
  const rewriteAssets = (html, urlMap) => {
    for (const [orig, replacement] of Object.entries(urlMap)) {
      html = html.split(orig).join(replacement);
    }
    return html;
  };
  const inflateAndRewrite = async (frame) => {
    const [html, urlMap] = await Promise.all([inflate(frame.dom), inflateAssets(frame.domAssets)]);
    return rewriteAssets(html, urlMap);
  };
  return { inflateAndRewrite };
})();
</script>
<script>
(function () {
  const frames = JSON.parse(document.getElementById('storyboard-frames').textContent);
  const chapterPaths = JSON.parse(document.getElementById('storyboard-chapter-paths').textContent);
  const frame = document.getElementById('storyboard-frame');
  const notes = document.getElementById('storyboard-notes');
  const titleEl = document.querySelector('h1.test-title');
  const chapterSep = document.createElement('span');
  chapterSep.className = 'test-sep';
  chapterSep.textContent = '›';
  chapterSep.hidden = true;
  const chapterPath = document.createElement('span');
  chapterPath.className = 'chapter-path';
  if (titleEl) titleEl.append(chapterSep, chapterPath);
  const strip = document.querySelector('nav.storyboard-strip');
  const tiles = Array.from(document.querySelectorAll('.thumb-tile'));
  const playButton = document.getElementById('play-toggle');
  const speedSlider = document.getElementById('speed-slider');
  const speedReadout = document.getElementById('speed-readout');
  const speedKey = 'storyboard.playRateMs';

  tiles.forEach((t, i) => { domInflate.inflateAndRewrite(frames[i]).then(html => { t.querySelector('iframe').srcdoc = html; }); });

  let current = -1;
  let playTimer = null;
  let atEnd = false;
  let playRateMs = 1500;

  const isVisible = (i) => tiles[i].offsetParent !== null;
  const visible = () => tiles.map((_, i) => i).filter(isVisible);

  const apply = (i) => {
    if (i < 0 || i >= frames.length || i === current) return;
    current = i;
    domInflate.inflateAndRewrite(frames[i]).then(html => { if (current === i) frame.srcdoc = html; });
    notes.textContent = frames[i].notes || '';
    updateBreadcrumb(i);
  };

  const updateBreadcrumb = (i) => {
    const path = chapterPaths[i] || [];
    const hasAny = chapterPaths.some(p => p && p.length);
    const multipleDistinct = new Set(chapterPaths.map(p => (p || []).join('␀'))).size > 1;
    if (!hasAny || !multipleDistinct) {
      chapterPath.textContent = '';
      chapterPath.title = '';
      chapterSep.hidden = true;
      return;
    }
    const text = path.join(' › ');
    chapterPath.textContent = text;
    chapterPath.title = text;
    chapterSep.hidden = path.length === 0;
  };

  const show = (i, smooth) => {
    if (i < 0 || i >= frames.length) return;
    apply(i);
    tiles[i].scrollIntoView({ inline: 'center', block: 'nearest', behavior: smooth ? 'smooth' : 'auto' });
  };

  const updateButton = () => {
    playButton.classList.toggle('is-playing', !!playTimer);
    playButton.classList.toggle('is-finished', atEnd && !playTimer);
    playButton.setAttribute('aria-label', playTimer ? 'Pause' : atEnd ? 'Restart' : 'Play');
  };

  const setPlaying = (on) => {
    if (on === !!playTimer) return;
    if (on) { atEnd = false; playTimer = setInterval(advance, playRateMs); }
    else { clearInterval(playTimer); playTimer = null; }
    updateButton();
  };

  const advance = () => {
    const vis = visible();
    if (!vis.length) return setPlaying(false);
    const pos = vis.indexOf(current);
    if (pos < 0) return show(vis[0], true);
    if (pos + 1 >= vis.length) { atEnd = true; return setPlaying(false); }
    show(vis[pos + 1], true);
  };

  const stopPlayback = () => {
    if (playTimer) setPlaying(false);
    if (atEnd) { atEnd = false; updateButton(); }
  };

  const applyRate = (ms) => {
    playRateMs = ms;
    speedReadout.textContent = (ms / 1000).toFixed(2).replace(/\.?0+$/, '') + 's';
    if (playTimer) { clearInterval(playTimer); playTimer = setInterval(advance, playRateMs); }
  };

  const stored = parseInt(localStorage.getItem(speedKey), 10);
  if (stored >= 250 && stored <= 4000) speedSlider.value = stored;
  applyRate(parseInt(speedSlider.value, 10));

  speedSlider.addEventListener('input', () => {
    const ms = parseInt(speedSlider.value, 10);
    applyRate(ms);
    try { localStorage.setItem(speedKey, String(ms)); } catch (e) { /* private mode */ }
  });

  playButton.addEventListener('click', () => {
    if (playTimer) return setPlaying(false);
    if (atEnd) {
      const vis = visible();
      if (!vis.length) return;
      show(vis[0], false);
    }
    setPlaying(true);
  });

  let scrollTimer;
  strip.addEventListener('scroll', () => {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(() => {
      const cx = strip.getBoundingClientRect().left + strip.clientWidth / 2;
      let best = current, bestDist = Infinity;
      visible().forEach((idx) => {
        const br = tiles[idx].getBoundingClientRect();
        const d = Math.abs(br.left + br.width / 2 - cx);
        if (d < bestDist) { bestDist = d; best = idx; }
      });
      apply(best);
    }, 80);
  });

  tiles.forEach((t, idx) => t.addEventListener('click', () => { stopPlayback(); show(idx, true); }));

  document.querySelectorAll('.chapter-divider').forEach((d) => {
    const target = parseInt(d.getAttribute('data-jump-to'), 10);
    if (Number.isFinite(target)) d.addEventListener('click', () => { stopPlayback(); show(target, true); });
  });

  document.addEventListener('keydown', (e) => {
    const t = document.activeElement;
    if (t && (t.tagName === 'INPUT' || t.tagName === 'SELECT' || t.tagName === 'TEXTAREA')) return;
    const dir = (e.key === 'ArrowDown' || e.key === 'ArrowRight') ? 1
              : (e.key === 'ArrowUp' || e.key === 'ArrowLeft') ? -1 : 0;
    if (!dir) return;
    const vis = visible(), next = vis.indexOf(current) + dir;
    if (next >= 0 && next < vis.length) {
      stopPlayback();
      show(vis[next], true);
      e.preventDefault();
    }
  });

  document.querySelectorAll('input[name="mode"]').forEach((r) =>
    r.addEventListener('change', () => {
      stopPlayback();
      if (current < 0 || !isVisible(current)) {
        const vis = visible();
        if (vis.length) show(vis[0], false);
      }
    })
  );

  const first = visible()[0];
  if (first !== undefined) show(first, false);
})();
</script>
<footer class="app-footer">
    Generated by http4k Storyboard · <a href="https://http4k.org" target="_blank">http4k.org</a>
</footer>
</body>
</html>
