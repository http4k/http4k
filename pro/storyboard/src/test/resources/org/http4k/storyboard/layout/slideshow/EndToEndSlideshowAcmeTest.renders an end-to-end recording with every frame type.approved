<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Storyboard: renders an end-to-end recording with every frame type</title>
<link rel="icon" type="image/png" sizes="32x32" href="https://http4k.org/favicon-16.png">
<link rel="icon" type="image/png" sizes="16x16" href="https://http4k.org/favicon-32.png">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css">
<style>
:root {
    --color-text: #2d3436;
    --color-text-muted: #636e72;
    --color-border: #dfe6e9;
    --color-bg-light: #f6f8fa;
    --color-bg-hover: #e0e6eb;
    --color-accent: #00b894;
    --color-link: #0984e3;
}
* { box-sizing: border-box; }
html, body { height: 100%; }
body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #fff;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
}
.app-header {
    background: linear-gradient(135deg, #1a2a6c 0%, #b21f1f 50%, #fdbb2d 100%);
    background-size: cover;
    background-position: center;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
}
.app-header-brand { display: flex; align-items: center; gap: 12px; }
.app-logo { height: 36px; }
.app-header-title { font-size: 18px; font-weight: 500; color: #fff; }
h1.test-title { margin: 0; padding: 12px 20px; font-size: 16px; font-weight: 500; color: var(--color-text); background: var(--color-bg-light); border-bottom: 1px solid var(--color-border); flex-shrink: 0; display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
h1.test-title .test-breadcrumb { font-size: 16px; font-weight: 500; color: inherit; text-decoration: none; }
h1.test-title a.test-breadcrumb:hover { text-decoration: underline; }
h1.test-title .test-sep { color: var(--color-text-muted); font-weight: 400; }
h1.test-title .test-heading { font-weight: 500; }
footer.app-footer { text-align: center; padding: 10px 0; font-size: 0.85rem; color: var(--color-text-muted); border-top: 1px solid var(--color-border); background: var(--color-bg-light); flex-shrink: 0; }
footer.app-footer a { color: var(--color-text-muted); }
.mode-toggle { display: inline-flex; gap: 6px; align-items: center; }
.mode-toggle .btn-group {
    position: relative;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    overflow: hidden;
    display: inline-flex;
}
.mode-toggle .btn-group::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-accent);
    transform: translateY(100%);
    transition: transform 0.25s ease;
    z-index: 0;
}
.mode-toggle .btn-group:has(.btn-check:checked)::before { transform: translateY(0); }
.mode-toggle .btn {
    position: relative;
    z-index: 1;
    font-size: 11px;
    padding: 4px 14px;
    text-align: center;
    background: transparent !important;
    border: 0 !important;
    border-radius: 999px !important;
    color: var(--color-text-muted);
    transition: color 0.25s ease;
    box-shadow: none !important;
}
.mode-toggle .btn-check:checked + .btn { color: #fff; }
body:has(#mode-story:checked) [data-level="Context"],
body:has(#mode-story:checked) [data-level="Detail"] { display: none; }
body:has(#mode-context:checked) [data-level="Detail"] { display: none; }
:root { --thumb-width: 133px; }
body { font-size: 13px; overflow: hidden; }
main.storyboard-view { display: flex; flex-direction: row; flex: 1; min-width: 0; min-height: 0; padding: 12px; gap: 8px; }
main.storyboard-view .notes { flex: 0 0 280px; padding: 8px 10px; background: var(--color-bg-light); border: 1px solid var(--color-border); border-radius: 4px; white-space: pre-wrap; overflow-y: auto; font-size: 13px; color: #495057; }
.frame-wrapper { position: relative; flex: 1; min-width: 0; }
.frame-wrapper iframe { width: 100%; height: 100%; display: block; border: 1px solid var(--color-border); border-radius: 4px; background: #fff; outline: none; }
.frame-overlay { position: absolute; top: 0; left: 0; right: 16px; bottom: 16px; background: transparent; cursor: default; }
.mode-bar { flex-shrink: 0; background: var(--color-bg-light); border-top: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 6px 12px; }
.play-toggle { display: inline-flex; align-items: center; gap: 8px; background: #fff; border: 1px solid var(--color-border); border-radius: 999px; padding: 4px 12px 4px 10px; font-size: 11px; color: var(--color-text-muted); cursor: pointer; transition: color 0.2s ease, border-color 0.2s ease; }
.play-toggle:hover { color: var(--color-text); border-color: var(--color-text-muted); }
.play-toggle:focus-visible { outline: 2px solid #9ec5fe; outline-offset: 2px; }
.play-toggle .play-icon { display: inline-flex; align-items: center; justify-content: center; width: 12px; color: var(--color-accent); font-size: 11px; line-height: 1; }
.play-toggle .play-icon::before { content: '\25B6'; }
.play-toggle.is-playing .play-icon::before { content: '\23F8'; }
.play-toggle .play-label::after { content: 'Play'; }
.play-toggle.is-playing .play-label::after { content: 'Pause'; }
.play-toggle.is-finished .play-icon::before { content: '\21BB'; }
.play-toggle.is-finished .play-label::after { content: 'Restart'; }
.playback { display: inline-flex; align-items: center; gap: 10px; }
.playback .speed { display: inline-flex; align-items: center; gap: 8px; font-size: 11px; color: var(--color-text-muted); }
.playback .speed-slider { -webkit-appearance: none; appearance: none; width: 120px; height: 4px; background: var(--color-border); border-radius: 999px; outline: none; cursor: pointer; }
.playback .speed-slider::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 14px; height: 14px; border-radius: 50%; background: var(--color-accent); border: 2px solid #fff; box-shadow: 0 0 0 1px var(--color-border); cursor: pointer; }
.playback .speed-slider::-moz-range-thumb { width: 14px; height: 14px; border-radius: 50%; background: var(--color-accent); border: 2px solid #fff; box-shadow: 0 0 0 1px var(--color-border); cursor: pointer; }
.playback .speed-slider:focus-visible { outline: 2px solid #9ec5fe; outline-offset: 4px; }
.playback .speed-readout { font-variant-numeric: tabular-nums; min-width: 32px; text-align: right; color: var(--color-text); }
.storyboard-strip-wrap { position: relative; flex-shrink: 0; background: var(--color-bg-light); border-top: 1px solid var(--color-border); }
nav.storyboard-strip {
    display: flex;
    flex-direction: row;
    gap: 8px;
    padding: 10px calc(50% - (var(--thumb-width) / 2));
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
}
nav.storyboard-strip::-webkit-scrollbar { display: none; }
.strip-selection {
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 50%;
    width: calc(var(--thumb-width) + 8px);
    transform: translateX(-50%);
    border: 2px solid var(--color-accent);
    border-radius: 8px;
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 20%, transparent);
    pointer-events: none;
    z-index: 2;
}
.thumb-tile { flex: 0 0 auto; width: var(--thumb-width); scroll-snap-align: center; padding: 6px; border: 1px solid transparent; border-radius: 6px; background: #fff; cursor: pointer; text-align: left; outline: none; }
.thumb-tile:focus { outline: none; }
.thumb-tile:focus-visible { outline: 2px solid #9ec5fe; outline-offset: 2px; }
.thumb-tile:hover { border-color: var(--color-border); }
.thumb-frame { position: relative; width: 100%; height: 78px; overflow: hidden; border: 1px solid var(--color-border); border-radius: 4px; background: #fff; }
.thumb-frame iframe { width: 1280px; height: 750px; border: 0; transform: scale(0.104); transform-origin: top left; }
.thumb-overlay { position: absolute; inset: 0; background: transparent; cursor: pointer; }
.thumb-title { display: block; margin-top: 4px; font-size: 12px; color: var(--color-text); word-break: break-word; }
h1.test-title .chapter-path { font-weight: 400; color: var(--color-text-muted); font-style: italic; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1 1 auto; }
.chapter-divider { flex: 0 0 auto; align-self: stretch; display: flex; align-items: center; padding: 0 8px; border-left: 1px dashed var(--color-border); cursor: pointer; user-select: none; overflow: hidden; }
.chapter-divider:hover { background: color-mix(in srgb, var(--color-accent) 6%, transparent); }
.chapter-divider-label { writing-mode: vertical-rl; transform: rotate(180deg); font-size: 11px; color: var(--color-text-muted, #6c757d); text-transform: uppercase; letter-spacing: 0.5px; white-space: nowrap; max-height: 100%; overflow: hidden; text-overflow: ellipsis; }
</style>
<link rel="preconnect" href="https://fonts.googleapis.com">
</head>
<body>
<header class="app-header">
    <div class="app-header-brand">
        <a href="https://acme.example.com" target="_blank"><img class="app-logo" src="https://static.wikia.nocookie.net/fictionalcompanies/images/c/c2/ACME_Corporation.png/revision/latest" alt="Acme Docs"></a>
        <span class="app-header-title">Acme Docs</span>
    </div>
</header>
<h1 class="test-title">
    <a class="test-breadcrumb" href="index.html">EndToEndSlideshowAcmeTest</a><span class="test-sep">›</span>
    <span class="test-heading">renders an end-to-end recording with every frame type</span>
</h1>
<main class="storyboard-view">
    <div class="frame-wrapper">
        <iframe id="storyboard-frame" sandbox="allow-scripts"></iframe>
        <div class="frame-overlay" aria-hidden="true"></div>
    </div>
    <div class="notes" id="storyboard-notes"></div>
</main>
<div class="mode-bar">
    <div class="playback">
        <button type="button" id="play-toggle" class="play-toggle" aria-label="Play">
            <span class="play-icon" aria-hidden="true"></span>
            <span class="play-label"></span>
        </button>
        <label class="speed">
            <input type="range" id="speed-slider" class="speed-slider" min="250" max="4000" step="50" value="1500" aria-label="Playback speed">
            <span id="speed-readout" class="speed-readout">1.5s</span>
        </label>
    </div>
<div class="mode-toggle" role="group" aria-label="Detail level">
    <div class="btn-group">
        <input type="radio" class="btn-check" name="mode" id="mode-story" autocomplete="off" checked>
        <label class="btn" for="mode-story">Story</label>
    </div>
    <div class="btn-group">
        <input type="radio" class="btn-check" name="mode" id="mode-context" autocomplete="off" >
        <label class="btn" for="mode-context">Context</label>
    </div>
    <div class="btn-group">
        <input type="radio" class="btn-check" name="mode" id="mode-detail" autocomplete="off" >
        <label class="btn" for="mode-detail">Detail</label>
    </div>
</div>
</div>
<div class="storyboard-strip-wrap">
    <nav class="storyboard-strip">
        <button type="button" class="thumb-tile" data-index="0" data-level="Context">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">Sample image</span>
        </button>
        <div class="chapter-divider" data-jump-to="1" title="Setup">
            <span class="chapter-divider-label">Setup</span>
        </div>
        <button type="button" class="thumb-tile" data-index="1" data-level="Context">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">Splash</span>
        </button>
        <button type="button" class="thumb-tile" data-index="2" data-level="Context">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">Sample source</span>
        </button>
        <div class="chapter-divider" data-jump-to="3" title="Run">
            <span class="chapter-divider-label">Run</span>
        </div>
        <button type="button" class="thumb-tile" data-index="3" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">postgresql SELECT</span>
        </button>
        <button type="button" class="thumb-tile" data-index="4" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">SERVER GET data</span>
        </button>
        <button type="button" class="thumb-tile" data-index="5" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">CLIENT GET /data</span>
        </button>
        <button type="button" class="thumb-tile" data-index="6" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">SERVER GET home</span>
        </button>
        <button type="button" class="thumb-tile" data-index="7" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">CLIENT GET /home</span>
        </button>
        <button type="button" class="thumb-tile" data-index="8" data-level="Story">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">Home</span>
        </button>
        <div class="chapter-divider" data-jump-to="9" title="Detail">
            <span class="chapter-divider-label">Detail</span>
        </div>
        <button type="button" class="thumb-tile" data-index="9" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">postgresql SELECT</span>
        </button>
        <button type="button" class="thumb-tile" data-index="10" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">SERVER GET data</span>
        </button>
        <button type="button" class="thumb-tile" data-index="11" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">CLIENT GET /data</span>
        </button>
        <button type="button" class="thumb-tile" data-index="12" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">SERVER GET detail</span>
        </button>
        <button type="button" class="thumb-tile" data-index="13" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">CLIENT GET /detail</span>
        </button>
        <button type="button" class="thumb-tile" data-index="14" data-level="Detail">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">click [By.id: next]</span>
        </button>
        <button type="button" class="thumb-tile" data-index="15" data-level="Story">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">Detail page</span>
        </button>
        <div class="chapter-divider" data-jump-to="16" title="Wrap-up">
            <span class="chapter-divider-label">Wrap-up</span>
        </div>
        <button type="button" class="thumb-tile" data-index="16" data-level="Context">
            <div class="thumb-frame">
                <iframe sandbox="allow-scripts" class="thumb-iframe"></iframe>
                <span class="thumb-overlay"></span>
            </div>
            <span class="thumb-title">Outro</span>
        </button>
    </nav>
    <div class="strip-selection" aria-hidden="true"></div>
</div>
<script type="application/json" id="storyboard-frames">[{"title":"Sample image","notes":"","dom":"","level":"Context","domAssets":{}},{"title":"Splash","notes":"","dom":"","level":"Context","domAssets":{}},{"title":"Sample source","notes":"","dom":"","level":"Context","domAssets":{}},{"title":"postgresql SELECT","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"SERVER GET data","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"CLIENT GET /data","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"SERVER GET home","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"CLIENT GET /home","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"Home","notes":"first navigation","dom":"H4sIAAAAAAAA/y2OsQ7CMAxE936FyQ9ErMj1AkgMSDAgIcZQuyRSGldphODvaVMmn+5s38PN4bK/Pa5H8GWI1GAd6MUxYQklCp10ELSrRluTBp/KX2oA0G/pLrGrO7NerJHO6lgY+qwDhJQkwyT5HTrZAU4la3qRlxh1DdH+PbRjfeAgcGuSfIoBn6VvjWUpLkRDLwUWGZcjN2PYyjE3L9Q/u92JM8wAAAA=","level":"Story","domAssets":{}},{"title":"postgresql SELECT","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"SERVER GET data","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"CLIENT GET /data","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"SERVER GET detail","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"CLIENT GET /detail","notes":"","dom":"","level":"Detail","domAssets":{}},{"title":"click [By.id: next]","notes":"","dom":"H4sIAAAAAAAA/zVNOw7CMAzdcwpzAqsrevJCmWFgYTSKRSK5bYS8cHvSANPT++MwX063+/VMJRaXhAEoplkQNdxkttDq4C8DDy/hseW3JCKU6Rehpk/r/jTk9lezhh4Jtkgx943qutoL3Dm49SEeS723P38AmPB8ZpAAAAA=","level":"Detail","domAssets":{}},{"title":"Detail page","notes":"after the click","dom":"H4sIAAAAAAAA/zVNOw7CMAzdcwpzAqsrevJCmWFgYTSKRSK5bYS8cHvSANPT++MwX063+/VMJRaXhAEoplkQNdxkttDq4C8DDy/hseW3JCKU6Rehpk/r/jTk9lezhh4Jtkgx943qutoL3Dm49SEeS723P38AmPB8ZpAAAAA=","level":"Story","domAssets":{}},{"title":"Outro","notes":"","dom":"","level":"Context","domAssets":{}}]</script>
