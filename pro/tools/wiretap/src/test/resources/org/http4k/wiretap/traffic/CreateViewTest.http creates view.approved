event: datastar-patch-elements
data: elements <div class="tab-btn" data-tab-id="-3" data-class:active="$activeView==='-3'"     data-on:click="@post('/_wiretap/traffic/views/-3/activate')">    <span>All</span></div><div class="tab-btn" data-tab-id="-2" data-class:active="$activeView==='-2'"     data-on:click="@post('/_wiretap/traffic/views/-2/activate')">    <span>Inbound</span></div><div class="tab-btn" data-tab-id="-1" data-class:active="$activeView==='-1'"     data-on:click="@post('/_wiretap/traffic/views/-1/activate')">    <span>Outbound</span></div><div class="tab-btn" data-tab-id="4" data-class:active="$activeView==='4'"     data-on:click="@post('/_wiretap/traffic/views/4/activate')">    <span>API</span></div><div class="add-tab-btn" data-on:click="$showAddView=!$showAddView; $name=''"><i class="bi bi-plus-lg"></i> Add Tab</div><div class="action-btn action-btn-danger" style="margin-left: auto" data-on:click="@delete('/_wiretap/traffic')"><i class="bi bi-trash"></i> Clear</div>
data: selector #tab-bar
data: mode inner

event: datastar-patch-signals
data: signals {"showAddView":false,"name":""}
data: onlyIfMissing false

