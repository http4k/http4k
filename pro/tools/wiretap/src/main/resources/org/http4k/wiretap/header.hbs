<script>
    document.querySelectorAll('#app-nav .nav-link').forEach(function (a) {
        var href = a.getAttribute('href');
        if (href === location.pathname || (href !== '/_wiretap' && location.pathname.startsWith(href))) {
            a.classList.add('nav-link-active');
        }
    });
</script>
