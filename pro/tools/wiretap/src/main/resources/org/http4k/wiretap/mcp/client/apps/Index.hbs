{{#>org/http4k/wiretap/layout pageTitle="MCP Client - Apps"}}
{{#partial "body"}}
<body class="d-flex flex-column h-100" data-signals="{{initialSignals}}">
{{> org/http4k/wiretap/header}}

{{> org/http4k/wiretap/mcp/client/McpClientSubnav}}

<div class="app-layout mcp-client-layout">
    <div class="mcp-client-list">
        <div class="mcp-client-list-header">Apps ({{tools.length}})</div>
        {{#each tools}}
        <div class="mcp-client-item"
             data-class-mcp-client-item-active="$selectedServerId==='{{this.serverId}}'"
             data-on:click="$selectedServerId='{{this.serverId}}'; $iframeVisible=true; loadMcpApp('{{this.serverId}}', '{{this.resourceUri}}')">
            <div class="mcp-client-item-name">{{this.uiToolName}}</div>
            <div class="mcp-client-item-desc">{{this.serverName}}</div>
        </div>
        {{/each}}
        {{#unless tools}}
        <div class="mcp-client-empty">No apps available</div>
        {{/unless}}
    </div>

    <div class="mcp-client-detail" id="detail-panel">
        <div class="mcp-client-placeholder" data-show="!$iframeVisible">Select an app to launch</div>
        <iframe id="app" class="mcp-app-iframe" data-show="$iframeVisible" style="width: 100%; height: 100%; border: none;"></iframe>
    </div>
</div>

<script>
    const basePath = '/_wiretap/mcp/inbound/apps';
    let currentServerId = null;

    async function loadMcpApp(serverId, uri) {
        currentServerId = serverId;
        const res = await fetch(`${basePath}/api/resources?serverId=${serverId}&uri=${encodeURIComponent(uri)}`);
        const csp = res.headers.get('Content-Security-Policy');
        let html = await res.text();

        if (csp) {
            html = `<meta http-equiv="Content-Security-Policy" content="${csp}; style-src * 'unsafe-inline'; script-src * 'unsafe-inline'">` + html;
        }

        document.getElementById('app').srcdoc = html;
    }

    addEventListener('message', async e => {
        if (!e.data?.jsonrpc || e.data.id === undefined) return;

        let result;
        switch (e.data.method) {
            case 'ui/initialize':
                result = {
                    protocolVersion: '2025-03-26',
                    hostInfo: {name: 'http4k-mcp-apps-host', version: '0.0.0'},
                    hostCapabilities: {serverTools: {}, openLinks: {}, updateModelContext: {text: {}}},
                    hostContext: {theme: 'light', platform: 'web', displayMode: 'inline', availableDisplayModes: ['inline']}
                };
                break;

            case 'tools/call':
                result = await fetch(`${basePath}/api/tools/call`, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({serverId: currentServerId, ...e.data.params})
                }).then(r => r.json());
                break;

            case 'ui/openLink':
                window.open(e.data.params.url, '_blank');
                result = {};
                break;

            case 'ui/message':
            case 'ui/updateModelContext':
            case 'ui/requestDisplayMode':
                result = {};
                break;

            default:
                e.source.postMessage({
                    jsonrpc: '2.0', id: e.data.id,
                    error: {code: -32601, message: 'Method not found'}
                }, '*');
                return;
        }

        e.source.postMessage({jsonrpc: '2.0', id: e.data.id, result}, '*');
    });
</script>

{{> org/http4k/wiretap/footer}}
</body>
{{/partial}}
{{/layout}}
