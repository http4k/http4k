<div id="mcp-content" class="app-layout mcp-client-layout">
    <div class="mcp-client-list">
        <div class="mcp-client-list-header">Tools ({{tools.length}})</div>
        {{#each tools}}
        <div class="mcp-client-item"
             data-class-mcp-client-item-active="$selectedItem==='{{this.name}}'"
             data-on:click="$selectedItem='{{this.name}}'; @get('/_wiretap/mcp/detail/tools/{{this.name}}')">
            <div class="mcp-client-item-name">{{this.name}}</div>
            <div class="mcp-client-item-desc">{{this.description}}</div>
        </div>
        {{/each}}
        {{#unless tools}}
        <div class="mcp-client-empty">No tools available</div>
        {{/unless}}
    </div>

    <div class="mcp-client-detail" id="detail-panel">
        <div class="mcp-client-placeholder">Select a tool to view details and call it</div>
    </div>
</div>
