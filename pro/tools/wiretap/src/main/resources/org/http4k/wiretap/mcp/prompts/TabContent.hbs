<div id="mcp-content" class="app-layout mcp-client-layout">
    <div class="mcp-client-list">
        <div class="mcp-client-list-header">Prompts ({{prompts.length}})</div>
        {{#each prompts}}
        <div class="mcp-client-item"
             data-class-mcp-client-item-active="$selectedItem==='{{this.name}}'"
             data-on:click="$selectedItem='{{this.name}}'; @get('/_wiretap/mcp/detail/prompts/{{this.name}}')">
            <div class="mcp-client-item-name">{{this.name}}</div>
            <div class="mcp-client-item-desc">{{this.description}}</div>
        </div>
        {{/each}}
        {{#unless prompts}}
        <div class="mcp-client-empty">No prompts available</div>
        {{/unless}}
    </div>

    <div class="mcp-client-detail" id="detail-panel">
        <div class="mcp-client-placeholder">Select a prompt to view details and get it</div>
    </div>
</div>
