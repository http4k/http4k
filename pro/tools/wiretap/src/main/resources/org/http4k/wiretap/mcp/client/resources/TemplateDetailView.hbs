<div id="detail-panel" data-signals="{resourceUri: '{{uriTemplate}}'}">
    <div class="mcp-client-detail-header">
        <h3>{{name}}</h3>
        <p>{{description}}</p>
    </div>
    <div class="mcp-client-detail-section">
        <label>URI Template</label>
        <code>{{uriTemplate}}</code>
        {{#if mimeType}}<br><label>MIME Type</label><code>{{mimeType}}</code>{{/if}}
    </div>
    <div class="mcp-client-detail-section">
        <label>Resource URI</label>
        <input type="text" class="mcp-client-input" data-bind="resourceUri" placeholder="Enter resolved URI" value="{{uriTemplate}}">
    </div>
    <button class="mcp-client-btn" data-on:click="@post('/_wiretap/mcp/inbound/api/resources/read')">Read Resource</button>
    <div id="resource-result" class="mcp-client-result"></div>
</div>
