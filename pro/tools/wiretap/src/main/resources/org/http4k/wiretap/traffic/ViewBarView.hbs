{{#each tabs}}
<div class="tab-btn" data-tab-id="{{id}}" data-class:active="$activeView==='{{id}}'"
     data-on:click="@post('/_wiretap/traffic/views/{{id}}/activate')">
    <span>{{name}}</span>
</div>
{{/each}}
<div class="add-tab-btn" data-on:click="$showAddView=!$showAddView; $name=''"><i class="bi bi-plus-lg"></i> Add Tab</div>
<div class="clear-btn" data-on:click="@delete('/_wiretap/traffic')"><i class="bi bi-trash"></i> Clear</div>
